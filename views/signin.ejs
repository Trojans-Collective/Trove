<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TROVE — Enter the Battleground</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cinzel:wght@400;600;700;900&family=Cinzel+Decorative:wght@400;700&family=DM+Mono:wght@300;400;500&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />

  <style>
    /* ══════════════════ TOKENS ══════════════════ */
    :root {
      --c-black:  #000000;
      --c-cyan:   #92DCE5;
      --c-cream:  #EEE5E9;
      --c-grey:   #7C7C7C;
      --c-red:    #D64933;
      --ease:     cubic-bezier(.77,0,.18,1);
    }
    [data-theme="dark"] {
      --bg:        #000000;
      --bg2:       #080808;
      --surface:   #0e0e0e;
      --surface2:  #161616;
      --border:    rgba(146,220,229,.1);
      --border-h:  rgba(146,220,229,.3);
      --text:      #EEE5E9;
      --text-dim:  rgba(238,229,233,.55);
      --text-muted:#7C7C7C;
      --accent:    #92DCE5;
      --accent2:   #D64933;
      --glow:      rgba(146,220,229,.15);
      --glow2:     rgba(214,73,51,.15);
      --ink:       rgba(146,220,229,.04);
    }
    [data-theme="light"] {
      --bg:        #EEE5E9;
      --bg2:       #e0d6db;
      --surface:   #f5f0f2;
      --surface2:  #ffffff;
      --border:    rgba(0,0,0,.1);
      --border-h:  rgba(0,100,110,.35);
      --text:      #000000;
      --text-dim:  rgba(0,0,0,.55);
      --text-muted:#7C7C7C;
      --accent:    #1a7a85;
      --accent2:   #D64933;
      --glow:      rgba(0,0,0,.06);
      --glow2:     rgba(214,73,51,.1);
      --ink:       rgba(0,0,0,.03);
    }

    /* ══════════════════ RESET ══════════════════ */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: 'DM Mono', monospace;
      background: var(--bg);
      color: var(--text);
      transition: background .7s var(--ease), color .7s var(--ease);
      user-select: none;
    }

    /* ══════════════════ CANVAS ══════════════════ */
    #bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ══════════════════ GRAIN OVERLAY ══════════════════ */
    .grain {
      position: fixed;
      inset: -50%;
      width: 200%; height: 200%;
      z-index: 1;
      pointer-events: none;
      opacity: .025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      animation: grainShift 0.4s steps(1) infinite;
    }
    @keyframes grainShift {
      0%  { transform: translate(0,0); }
      25% { transform: translate(-2%,-3%); }
      50% { transform: translate(3%, 1%); }
      75% { transform: translate(-1%, 4%); }
    }
    [data-theme="dark"] .grain { opacity: .04; }

    /* ══════════════════ LAYOUT SHELL ══════════════════ */
    .shell {
      position: relative;
      z-index: 2;
      width: 100%; height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* ══════════════════ LEFT PANEL ══════════════════ */
    .panel-left {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 2.4rem 3rem;
      border-right: 1px solid var(--border);
      overflow: hidden;
    }

    /* Etched SVG crest background */
    .panel-left::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 520px; height: 520px;
      background: radial-gradient(ellipse at center, var(--glow) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    /* Decorative corner marks */
    .corner-mark {
      position: absolute;
      width: 18px; height: 18px;
      border-color: var(--border-h);
      border-style: solid;
    }
    .corner-mark.tl { top: 1.5rem; left: 1.5rem; border-width: 1px 0 0 1px; }
    .corner-mark.tr { top: 1.5rem; right: 1.5rem; border-width: 1px 1px 0 0; }
    .corner-mark.bl { bottom: 1.5rem; left: 1.5rem; border-width: 0 0 1px 1px; }
    .corner-mark.br { bottom: 1.5rem; right: 1.5rem; border-width: 0 1px 1px 0; }

    /* Logo */
    .logo-wrap { position: relative; z-index: 1; }
    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.9rem;
      letter-spacing: .22em;
      color: var(--accent);
      text-decoration: none;
      display: inline-block;
    }
    .logo span { color: var(--accent2); }
    .logo-tag {
      font-size: .55rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: .2rem;
    }

    /* Crest center */
    .crest-wrap {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      z-index: 1;
      pointer-events: none;
    }

    .crest-svg {
      width: 280px;
      height: auto;
      opacity: .25;
      animation: crestFloat 8s ease-in-out infinite, crestRotate 20s linear infinite, crestPulse 4s ease-in-out infinite;
      filter: drop-shadow(0 0 30px var(--accent)) drop-shadow(0 0 60px var(--accent));
      transform-style: preserve-3d;
      perspective: 1000px;
    }
    [data-theme="light"] .crest-svg { 
      opacity: .55;
      filter: drop-shadow(0 0 25px rgba(26,122,133,.6)) drop-shadow(0 0 50px rgba(26,122,133,.4));
    }

    @keyframes crestFloat {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      33%       { transform: translateY(-10px) rotate(.5deg); }
      66%       { transform: translateY(5px) rotate(-.3deg); }
    }

    @keyframes crestRotate {
      0%   { transform: translateY(0px) rotateZ(0deg); }
      100% { transform: translateY(0px) rotateZ(360deg); }
    }

    @keyframes crestPulse {
      0%, 100% { filter: drop-shadow(0 0 30px var(--accent)) drop-shadow(0 0 60px var(--accent)); }
      50%      { filter: drop-shadow(0 0 50px var(--accent)) drop-shadow(0 0 90px var(--accent)); }
    }
    /* This Controls the position */
    @keyframes orbiterSpin {
      0%   { transform: rotate(0deg) translateX(70px) rotate(0deg); opacity: .6; }
      25%  { opacity: .9; }
      50%  { opacity: .6; }
      75%  { opacity: .9; }
      100% { transform: rotate(360deg) translateX(70px) rotate(-360deg); opacity: .6; }
    }

    @keyframes energyRing {
      0%   { transform: scale(0.8) rotate(0deg); opacity: .3; }
      50%  { transform: scale(1.2) rotate(180deg); opacity: .6; }
      100% { transform: scale(0.8) rotate(360deg); opacity: .3; }
    }

    /* Energy orbiting elements */
    .crest-energy {
      position: absolute;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      top: 50%;
      left: 50%;
      pointer-events: none;
      transform-origin: 0 0;
    }

    .crest-energy.e1 {
      background: var(--accent);
      animation: orbiterSpin 12s linear infinite;
      box-shadow: 0 0 10px var(--accent), 0 0 20px var(--accent);
    }

    .crest-energy.e2 {
      background: var(--accent2);
      animation: orbiterSpin 12s linear infinite reverse;
      box-shadow: 0 0 10px var(--accent2), 0 0 20px var(--accent2);
      animation-delay: 4s;
    }

    .crest-energy.e3 {
      background: var(--accent);
      width: 8px;
      height: 8px;
      animation: orbiterSpin 12s linear infinite;
      animation-delay: 8s;
      box-shadow: 0 0 8px var(--accent);
    }

    [data-theme="light"] .crest-energy.e1 {
      background: rgba(26,122,133,.9);
      box-shadow: 0 0 12px rgba(26,122,133,1), 0 0 24px rgba(26,122,133,.7);
    }

    [data-theme="light"] .crest-energy.e2 {
      background: rgba(214,73,51,.9);
      box-shadow: 0 0 12px rgba(214,73,51,1), 0 0 24px rgba(214,73,51,.7);
    }

    [data-theme="light"] .crest-energy.e3 {
      background: rgba(26,122,133,.9);
      box-shadow: 0 0 10px rgba(26,122,133,.9);
    }

    /* Dynamic energy ring around crest */
    .crest-ring {
      position: absolute;
      width: 300px;
      height: 300px;
      border: 2px solid var(--accent);
      border-radius: 50%;
      top: 2%;
      left: 5%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      opacity: .2;
      animation: energyRing 6s ease-in-out infinite;
    }

    [data-theme="light"] .crest-ring {
      border-color: rgba(26,122,133,.7);
      opacity: .35;
    }

    /* Shield inner glow */
    .crest-glow {
      position: absolute;
      width: 280px;
      height: 280px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(ellipse at center, var(--accent), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      animation: glowPulse 4s ease-in-out infinite;
      opacity: .15;
      filter: blur(10px);
    }

    [data-theme="light"] .crest-glow {
      background: radial-gradient(ellipse at center, rgba(26,122,133,.6), transparent 70%);
      opacity: .25;
    }

    @keyframes glowPulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: .15; }
      50%      { transform: translate(-50%, -50%) scale(1.15); opacity: .25; }
    }

    /* SVG element animations */
    .shield-stroke {
      animation: strokeGlow 3s ease-in-out infinite;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .spear-line {
      animation: spearGlow 2.5s ease-in-out infinite;
    }

    .spear-tip {
      animation: tipPulse 2s ease-in-out infinite;
    }

    .crown-elem {
      animation: crownSpin 8s linear infinite;
      transform-origin: 150px 42px;
    }

    .laurel-elem {
      animation: laurelWave 4s ease-in-out infinite;
    }

    .shield-text {
      animation: textGlow 3.5s ease-in-out infinite;
    }

    .star {
      animation: starTwinkle 3s ease-in-out infinite;
    }

    .star-center {
      animation: starTwinkle 3s ease-in-out infinite 0.5s;
    }

    @keyframes strokeGlow {
      0%, 100% { stroke-width: 1.5; opacity: .8; }
      50%      { stroke-width: 2; opacity: 1; }
    }

    @keyframes spearGlow {
      0%, 100% { opacity: .6; stroke-width: 1; }
      50%      { opacity: 1; stroke-width: 1.3; }
    }

    @keyframes tipPulse {
      0%, 100% { opacity: .7; transform: scale(1); }
      50%      { opacity: 1; transform: scale(1.2); }
    }

    @keyframes crownSpin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes laurelWave {
      0%, 100% { opacity: .5; }
      50%      { opacity: .8; }
    }

    @keyframes textGlow {
      0%, 100% { opacity: .9; }
      50%      { opacity: 1; }
    }

    @keyframes starTwinkle {
      0%, 100% { opacity: .4; r: 2px; }
      50%      { opacity: .9; r: 3.5px; }
    }

    .crest-title {
      font-family: 'Cinzel Decorative', serif;
      font-size: .7rem;
      letter-spacing: .3em;
      color: var(--accent);
      opacity: .7;
      margin-top: 1.5rem;
      text-transform: uppercase;
    }

    /* Rank scroll at bottom of left panel */
    .rank-scroll {
      position: relative;
      z-index: 1;
    }
    .rank-scroll-label {
      font-size: .52rem;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .8rem;
    }
    .rank-line {
      display: flex;
      align-items: center;
      gap: .7rem;
      margin-bottom: .4rem;
      cursor: default;
    }
    .rank-pip {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--border-h);
      flex-shrink: 0;
      transition: background .3s, transform .3s;
    }
    .rank-line:hover .rank-pip { background: var(--accent); transform: scale(1.5); }
    .rank-name-sm {
      font-family: 'Cinzel', serif;
      font-size: .62rem;
      letter-spacing: .18em;
      color: var(--text-muted);
      transition: color .3s;
    }
    .rank-line:hover .rank-name-sm { color: var(--accent); }
    .rank-line.current .rank-pip { background: var(--accent2); }
    .rank-line.current .rank-name-sm { color: var(--accent2); }
    .rank-arrow {
      font-size: .55rem;
      color: var(--accent2);
      letter-spacing: .1em;
    }

    /* Divider line with glyph */
    .h-divider {
      display: flex;
      align-items: center;
      gap: .8rem;
      margin: .8rem 0;
    }
    .h-divider::before, .h-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .h-divider span {
      font-size: .55rem;
      color: var(--border-h);
      letter-spacing: .2em;
    }

    /* ══════════════════ RIGHT PANEL ══════════════════ */
    .panel-right {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 4rem;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* Theme toggle */
    .theme-btn {
      position: absolute;
      top: 2rem; right: 2rem;
      width: 48px; height: 26px;
      border-radius: 99px;
      background: var(--surface2);
      border: 1px solid var(--border);
      cursor: pointer;
      position: absolute;
      transition: background .4s;
    }
    .theme-btn::before {
      content: '';
      position: absolute;
      top: 3px; left: 3px;
      width: 18px; height: 18px;
      border-radius: 50%;
      background: var(--accent);
      transition: transform .4s cubic-bezier(.34,1.56,.64,1);
    }
    [data-theme="light"] .theme-btn::before { transform: translateX(22px); background: var(--accent2); }
    .theme-btn-label {
      position: absolute;
      top: 2rem; right: 5.5rem;
      font-size: .55rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text-muted);
      line-height: 26px;
    }

    /* Form container */
    .form-box {
      width: 100%;
      max-width: 420px;
      position: relative;
    }

    /* Tab switcher */
    .tab-switcher {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid var(--border);
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 2.4rem;
      background: var(--surface);
    }
    .tab-btn {
      padding: .85rem;
      text-align: center;
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--text-muted);
      cursor: pointer;
      border: none;
      background: transparent;
      transition: color .3s, background .3s;
      position: relative;
    }
    .tab-btn.active {
      color: var(--bg);
      background: var(--accent);
    }
    [data-theme="light"] .tab-btn.active { color: #fff; }
    .tab-btn:not(.active):hover { color: var(--accent); }

    /* Form heading */
    .form-heading {
      margin-bottom: .5rem;
    }
    .form-heading-main {
      font-family: 'Cinzel', serif;
      font-size: 1.55rem;
      font-weight: 700;
      letter-spacing: .06em;
      line-height: 1.1;
      color: var(--text);
    }
    .form-heading-sub {
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-size: 1rem;
      color: var(--text-muted);
      margin-top: .35rem;
      margin-bottom: 1.8rem;
      line-height: 1.5;
    }

    /* Social buttons */
    .social-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .8rem;
      margin-bottom: 1.4rem;
    }
    .social-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .65rem;
      padding: .85rem 1rem;
      border: 1px solid var(--border);
      border-radius: 3px;
      background: var(--surface);
      color: var(--text-dim);
      font-family: 'DM Mono', monospace;
      font-size: .62rem;
      letter-spacing: .1em;
      cursor: pointer;
      text-decoration: none;
      transition: border-color .25s, color .25s, background .25s, transform .25s, box-shadow .25s;
      position: relative;
      overflow: hidden;
    }
    .social-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent);
      opacity: 0;
      transition: opacity .3s;
    }
    .social-btn:hover {
      border-color: var(--border-h);
      color: var(--text);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px var(--glow);
    }
    .social-btn:hover::before { opacity: .05; }
    .social-btn svg {
      width: 16px; height: 16px;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }
    .social-btn span { position: relative; z-index: 1; }

    .social-btn.github-btn:hover { border-color: var(--text-muted); }
    .social-btn.google-btn:hover { border-color: #4285F4; box-shadow: 0 8px 24px rgba(66,133,244,.1); }

    /* OR divider */
    .or-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.2rem 0;
      font-size: .55rem;
      letter-spacing: .28em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .or-divider::before, .or-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* Input fields */
    .field-group { margin-bottom: 1rem; }
    .field-label {
      display: block;
      font-size: .55rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .5rem;
    }
    .field-wrap {
      position: relative;
    }
    .field-icon {
      position: absolute;
      left: 1rem; top: 50%;
      transform: translateY(-50%);
      font-size: .9rem;
      pointer-events: none;
      opacity: .4;
      transition: opacity .3s;
    }
    .field-input {
      width: 100%;
      padding: .85rem 1rem .85rem 2.7rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 3px;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: .72rem;
      letter-spacing: .06em;
      outline: none;
      transition: border-color .25s, box-shadow .25s, background .25s;
    }
    .field-input::placeholder { color: var(--text-muted); opacity: .5; }
    .field-input:focus {
      border-color: var(--accent);
      background: var(--surface2);
      box-shadow: 0 0 0 3px var(--glow);
    }
    .field-input:focus + .field-icon,
    .field-wrap:focus-within .field-icon { opacity: .8; }

    /* Password strength bar */
    .strength-bar {
      height: 2px;
      background: var(--border);
      border-radius: 99px;
      margin-top: .5rem;
      overflow: hidden;
      display: none;
    }
    .strength-bar-fill {
      height: 100%;
      border-radius: 99px;
      width: 0%;
      transition: width .4s var(--ease), background .4s;
      background: var(--accent2);
    }
    .field-group:focus-within .strength-bar { display: block; }

    /* Rank selector (sign up only) */
    .rank-selector {
      margin-bottom: 1rem;
    }
    .rank-selector-label {
      font-size: .55rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .5rem;
      display: block;
    }
    .rank-chips {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
    }
    .rank-chip {
      font-size: .55rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: .35rem .8rem;
      border: 1px solid var(--border);
      border-radius: 99px;
      color: var(--text-muted);
      cursor: default;
      background: var(--surface);
      transition: all .25s;
      font-family: 'Cinzel', serif;
    }
    .rank-chip.locked { opacity: .35; cursor: not-allowed; }
    .rank-chip.selected {
      border-color: var(--accent2);
      color: var(--accent2);
      background: rgba(214,73,51,.08);
      box-shadow: 0 0 12px var(--glow2);
    }
    .rank-chip.psilos {
      border-color: var(--border-h);
      color: var(--accent);
      background: rgba(146,220,229,.06);
      cursor: pointer;
    }
    .rank-note {
      font-size: .55rem;
      letter-spacing: .1em;
      color: var(--text-muted);
      margin-top: .5rem;
      font-style: italic;
    }

    /* Submit button */
    .submit-btn {
      width: 100%;
      padding: 1rem;
      background: var(--accent);
      border: none;
      border-radius: 3px;
      color: #000;
      font-family: 'Cinzel', serif;
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      margin-top: .4rem;
      transition: transform .25s, box-shadow .25s;
    }
    .submit-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent2);
      transform: translateX(-101%);
      transition: transform .45s var(--ease);
    }
    .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px var(--glow); }
    .submit-btn:hover::before { transform: translateX(0); }
    .submit-btn span { position: relative; z-index: 1; }
    .submit-btn:active { transform: scale(.98); }

    /* Terms */
    .terms-note {
      text-align: center;
      font-size: .52rem;
      letter-spacing: .12em;
      color: var(--text-muted);
      margin-top: 1.2rem;
      line-height: 1.8;
    }
    .terms-note a { color: var(--accent); text-decoration: none; }
    .terms-note a:hover { text-decoration: underline; }

    /* Oath text */
    .oath-block {
      margin-bottom: 1.6rem;
      padding: 1rem 1.2rem;
      border-left: 2px solid var(--accent2);
      background: var(--ink);
    }
    .oath-text {
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-size: .88rem;
      line-height: 1.7;
      color: var(--text-dim);
    }
    .oath-speaker {
      font-size: .55rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: .4rem;
    }

    /* Form toggle animation */
    .form-panel {
      transition: opacity .4s var(--ease), transform .4s var(--ease);
    }
    .form-panel.hidden {
      display: none;
    }

    /* Animated entrance */
    .form-box {
      animation: boxEntrance .8s var(--ease) both;
    }
    @keyframes boxEntrance {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Checkmark row */
    .check-row {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-bottom: .9rem;
      cursor: pointer;
    }
    .check-box {
      width: 14px; height: 14px;
      border: 1px solid var(--border);
      border-radius: 2px;
      flex-shrink: 0;
      background: var(--surface);
      position: relative;
      transition: border-color .25s, background .25s;
    }
    .check-row input { display: none; }
    .check-row input:checked ~ .check-box {
      background: var(--accent);
      border-color: var(--accent);
    }
    .check-row input:checked ~ .check-box::after {
      content: '✓';
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .55rem;
      color: #000;
    }
    .check-label {
      font-size: .58rem;
      letter-spacing: .1em;
      color: var(--text-muted);
      flex: 1;
    }

    /* ══════════════════ CURSOR ══════════════════ */
    .cursor {
      position: fixed;
      width: 7px; height: 7px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      mix-blend-mode: difference;
      transform: translate(-50%, -50%);
      transition: width .25s, height .25s;
    }
    .cursor-ring {
      position: fixed;
      width: 28px; height: 28px;
      border: 1px solid var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      opacity: .45;
      transition: width .3s, height .3s, opacity .3s;
    }
    .cursor-ring.expanded { width: 50px; height: 50px; opacity: .2; }

    /* ══════════════════ MOBILE ══════════════════ */
    @media (max-width: 860px) {
      .shell { grid-template-columns: 1fr; }
      .panel-left { display: none; }
      .panel-right { padding: 2rem 1.8rem; }
    }

    /* ══════════════════ SCROLL INSIDE RIGHT ══════════════════ */
    .panel-right::-webkit-scrollbar { width: 3px; }
    .panel-right::-webkit-scrollbar-track { background: transparent; }
    .panel-right::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }

    /* ══════════════════ INPUT FOCUS ANIMATION ══════════════════ */
    .field-input:focus { animation: fieldPulse .4s ease; }
    @keyframes fieldPulse {
      0%   { box-shadow: 0 0 0 0 var(--glow); }
      60%  { box-shadow: 0 0 0 6px transparent; }
      100% { box-shadow: 0 0 0 3px var(--glow); }
    }

    /* ══════════════════ FORGOT PASSWORD LINK ══════════════════ */
    .forgot-link {
      font-size: .55rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      float: right;
      transition: color .25s;
    }
    .forgot-link:hover { color: var(--accent); }

    /* Glow accent line across top of right panel */
    .panel-right::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--accent), transparent);
      opacity: .4;
    }

    /* Battle seal - decorative bottom-left in left panel */
    .battle-seal {
      position: absolute;
      bottom: 5rem;
      right: 2rem;
      font-size: .5rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--border-h);
      writing-mode: vertical-rl;
      text-orientation: mixed;
      pointer-events: none;
      opacity: .5;
    }

    /* Animated glowing orb behind crest */
    .orb {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 300px; height: 300px;
      border-radius: 50%;
      background: radial-gradient(ellipse at center, var(--glow) 0%, transparent 70%);
      animation: orbPulse 5s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes orbPulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: .7; }
      50%       { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
    }

    /* Tab underline indicator */
    .tab-indicator {
      position: absolute;
      bottom: 0;
      height: 2px;
      background: var(--accent2);
      transition: left .35s var(--ease), width .35s var(--ease);
    }

    /* Hover shimmer on submit */
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
  </style>
</head>
<body>

