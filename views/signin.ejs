<!-- ══════ TOAST NOTIFICATION ══════ -->
<div id="toast" style="
  position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(80px);
  background:var(--surface2);border:1px solid var(--border);border-radius:3px;
  padding:.8rem 1.6rem;font-size:.65rem;letter-spacing:.14em;color:var(--text);
  z-index:9999;transition:transform .4s var(--ease),opacity .4s;opacity:0;
  font-family:'DM Mono',monospace;white-space:nowrap;
  box-shadow:0 12px 32px rgba(0,0,0,.3);
" id="toast"></div>

<script>
/* ══════ CANVAS 3D ══════ */
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, particles = [];
let mx = 0, my = 0;
const html = document.documentElement;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
window.addEventListener('resize', () => { resize(); initP(); });
resize();
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });

function getC() {
  const d = html.getAttribute('data-theme') === 'dark';
  return {
    p: d ? 'rgba(146,220,229,' : 'rgba(0,110,120,',
    l: d ? 'rgba(146,220,229,' : 'rgba(0,100,110,',
    g: d ? 'rgba(146,220,229,' : 'rgba(0,100,110,',
    r: d ? 'rgba(214,73,51,'  : 'rgba(180,50,30,',
  };
}

class P {
  constructor() { this.reset(true); }
  reset(init) {
    this.x  = Math.random() * W;
    this.y  = init ? Math.random() * H : H + 10;
    this.z  = Math.random() * 500 + 100;
    this.vx = (Math.random()-.5) * .25;
    this.vy = -(Math.random() * .35 + .05);
    this.r  = Math.random() * 1.2 + .4;
    this.a  = Math.random() * .5 + .1;
    this.life = 0;
    this.max  = Math.random() * 350 + 200;
    this.isRed = Math.random() < .08;
  }
  tick() {
    const dx = mx - W/2, dy = my - H/2;
    this.x += this.vx + dx*.00006;
    this.y += this.vy + dy*.00006;
    this.life++;
    const fov = 350, s = fov/(fov+this.z);
    this.sx = (this.x - W/2)*s + W/2;
    this.sy = (this.y - H/2)*s + H/2;
    this.sr = this.r * s;
    this.sa = this.a * Math.min(this.life/50,1) * (1 - this.life/this.max);
    if (this.life > this.max || this.sx<-50 || this.sx>W+50 || this.sy<-50) this.reset();
  }
  draw(c) {
    ctx.beginPath();
    ctx.arc(this.sx, this.sy, Math.max(.1, this.sr), 0, Math.PI*2);
    const col = this.isRed ? c.r : c.p;
    ctx.fillStyle = col + this.sa + ')';
    ctx.fill();
  }
}

function initP() {
  particles = [];
  for (let i = 0; i < 80; i++) particles.push(new P());
}
initP();

function drawGrid(c) {
  const hor = H * .5;
  const vp  = W / 2;
  // vertical lines
  for (let i = -12; i <= 12; i++) {
    const wx = i * 90;
    const factor = H / (H - hor);
    ctx.beginPath();
    ctx.moveTo(vp + wx, hor);
    ctx.lineTo(vp + wx * factor * 2.5, H);
    const a = Math.max(0, .08 - Math.abs(i) * .006);
    ctx.strokeStyle = c.g + a + ')';
    ctx.lineWidth = .5;
    ctx.stroke();
  }
  // horizontal lines
  for (let j = 0; j <= 8; j++) {
    const t = j / 8;
    const y = hor + (H - hor) * Math.pow(t, 1.6);
    const sp = 180 + (y - hor)/(H-hor) * W * 1.4;
    ctx.beginPath();
    ctx.moveTo(vp - sp, y);
    ctx.lineTo(vp + sp, y);
    ctx.strokeStyle = c.g + (t * .09) + ')';
    ctx.lineWidth = .5;
    ctx.stroke();
  }
}

function drawConnections(c) {
  for (let i = 0; i < particles.length; i++) {
    for (let j = i+1; j < particles.length; j++) {
      const a = particles[i], b = particles[j];
      const dx = a.sx - b.sx, dy = a.sy - b.sy;
      const d = Math.sqrt(dx*dx+dy*dy);
      if (d < 80) {
        const col = (a.isRed || b.isRed) ? c.r : c.l;
        ctx.beginPath();
        ctx.moveTo(a.sx, a.sy);
        ctx.lineTo(b.sx, b.sy);
        ctx.strokeStyle = col + ((1-d/80)*.1) + ')';
        ctx.lineWidth = .4;
        ctx.stroke();
      }
    }
  }
}

(function loop() {
  ctx.clearRect(0, 0, W, H);
  const c = getC();
  drawGrid(c);
  drawConnections(c);
  particles.forEach(p => { p.tick(); p.draw(c); });
  requestAnimationFrame(loop);
})();

/* ══════ CURSOR ══════ */
const curEl = document.getElementById('cursor');
const curRing = document.getElementById('cursorRing');
let rx = -100, ry = -100, cmx = -100, cmy = -100;
document.addEventListener('mousemove', e => {
  cmx = e.clientX; cmy = e.clientY;
  curEl.style.left = cmx+'px'; curEl.style.top = cmy+'px';
});
(function curLoop() {
  rx += (cmx-rx)*.12; ry += (cmy-ry)*.12;
  curRing.style.left = rx+'px'; curRing.style.top = ry+'px';
  requestAnimationFrame(curLoop);
})();
document.querySelectorAll('a,button,.social-btn,.rank-line,.rank-chip,.check-row').forEach(el => {
  el.addEventListener('mouseenter', () => curRing.classList.add('expanded'));
  el.addEventListener('mouseleave', () => curRing.classList.remove('expanded'));
});

/* ══════ THEME TOGGLE ══════ */
document.getElementById('themeToggle').addEventListener('click', () => {
  const d = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', d ? 'light' : 'dark');
});

/* ══════ TAB SWITCH ══════ */
function switchTab(tab) {
  const siPanel = document.getElementById('panel-signin');
  const suPanel = document.getElementById('panel-signup');
  const siBtn   = document.getElementById('tab-signin');
  const suBtn   = document.getElementById('tab-signup');

  if (tab === 'signin') {
    siPanel.classList.remove('hidden');
    suPanel.classList.add('hidden');
    siBtn.classList.add('active');
    suBtn.classList.remove('active');
  } else {
    siPanel.classList.add('hidden');
    suPanel.classList.remove('hidden');
    suBtn.classList.add('active');
    siBtn.classList.remove('active');
  }
}

/* ══════ PASSWORD STRENGTH ══════ */
function updateStrength(input, barId) {
  const val = input.value;
  const bar = document.getElementById(barId);
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^a-zA-Z0-9]/.test(val)) score++;
  if (val.length >= 14) score++;

  const pct = (score / 5) * 100;
  bar.style.width = pct + '%';
  if (score <= 1)      bar.style.background = '#D64933';
  else if (score <= 2) bar.style.background = '#e09b3c';
  else if (score <= 3) bar.style.background = '#c4c94a';
  else                 bar.style.background = '#92DCE5';
}

/* ══════ TOAST ══════ */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.opacity = '1';
  t.style.transform = 'translateX(-50%) translateY(0)';
  setTimeout(() => {
    t.style.opacity = '0';
    t.style.transform = 'translateX(-50%) translateY(80px)';
  }, 3000);
}

/* ══════ FORM HANDLERS (frontend only) ══════ */
function handleSignIn() {
  const email = document.getElementById('si-email').value.trim();
  const pass  = document.getElementById('si-pass').value;
  if (!email || !pass) { showToast('⚠ A warrior identifies themselves fully.'); return; }
  showToast('⚔ Verifying your seal… (connect backend to proceed)');
}

function handleSignUp() {
  const name   = document.getElementById('su-name').value.trim();
  const handle = document.getElementById('su-handle').value.trim();
  const email  = document.getElementById('su-email').value.trim();
  const pass   = document.getElementById('su-pass').value;
  const terms  = document.getElementById('su-terms').checked;
  if (!name || !handle || !email || !pass) { showToast('⚠ Fill every field to complete your enlistment.'); return; }
  if (!terms) { showToast('⚠ Swear the Builder\'s Oath to proceed.'); return; }
  showToast('🛡 Enlistment received — connect backend to continue.');
}

/* ══════ 3D TILT on form box ══════ */
const formBox = document.querySelector('.panel-right');
formBox.addEventListener('mousemove', e => {
  const rect = formBox.getBoundingClientRect();
  const x = (e.clientX - rect.left) / rect.width  - .5;
  const y = (e.clientY - rect.top)  / rect.height - .5;
  const box = formBox.querySelector('.form-box');
  if (box) box.style.transform = `perspective(1000px) rotateY(${x*4}deg) rotateX(${-y*3}deg)`;
});
formBox.addEventListener('mouseleave', () => {
  const box = formBox.querySelector('.form-box');
  if (box) box.style.transform = '';
});
</script>
