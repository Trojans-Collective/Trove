<script>
/* ═══════════════════ STATE ═══════════════════ */
const html = document.documentElement;
let currentScreen = 'landing';
let currentStep = 0;
let answers = {};
let mx = 0, my = 0, rx = -200, ry = -200;

/* ═══════════════════ ONBOARDING STEPS ═══════════════════ */
const STEPS = [
  {
    id:'name',
    glyph:'🪬',
    num:'01',
    question:'What shall we <em>call you</em>, builder?',
    hint:'This becomes your display name across The Arena, The Codex, and your Builder Profile.',
    type:'text',
    placeholder:'Your builder name...',
    featureHint:{icon:'🧬',text:'<strong>Builder Profile</strong> — Your name appears on your public Identity Card, rank badge, and all project submissions in The Arena.'}
  },
  {
    id:'college',
    glyph:'🏛️',
    num:'02',
    question:'Which <em>institution</em> forged you?',
    hint:'Your college/university or professional workplace. Shown on your Identity Card.',
    type:'text',
    placeholder:'College name or Company...',
    featureHint:{icon:'🏟️',text:'<strong>The Arena</strong> — Projects are tagged with your institution, making college-specific leaderboards possible.'}
  },
  {
    id:'year',
    glyph:'📅',
    num:'03',
    question:'Which <em>year of the campaign</em> are you in?',
    hint:'Academic year or years of experience as a professional.',
    type:'chips',
    options:['1st Year','2nd Year','3rd Year','4th Year','Final Year','Alumni','Working Professional','Other'],
    featureHint:{icon:'📡',text:'<strong>Broadcast Beacon</strong> — Year-specific hackathon and internship opportunities are filtered just for you.'}
  },
  {
    id:'domain',
    glyph:'⚙️',
    num:'04',
    question:'What are your <em>weapon specialisations</em>?',
    hint:'Pick all that apply. These shape your tech stack identity and skill tags.',
    type:'multi-chips',
    options:['Full Stack','Frontend','Backend','Mobile','AI / ML','Cybersecurity','DevOps / Cloud','Blockchain','Data Science','UI / UX','Open Source','Embedded / IoT'],
    featureHint:{icon:'🧬',text:'<strong>Identity Layer</strong> — Skill tags are publicly visible on your profile and used for teammate matching in The Beacon.'}
  },
  {
    id:'experience',
    glyph:'⚔️',
    num:'05',
    question:'How long have you been <em>on the battlefield</em>?',
    hint:'Your overall coding / building experience — helps us set your starting difficulty.',
    type:'chips',
    options:['< 6 months','6–12 months','1–2 years','2–4 years','4+ years','Battle-hardened'],
    featureHint:{icon:'🏟️',text:'<strong>Arena Ranking</strong> — Experience level is factored into your rank progression speed and project difficulty tagging.'}
  },
  {
    id:'rank',
    glyph:'🛡️',
    num:'06',
    question:'Choose your <em>starting rank</em> in the lore',
    hint:'Self-declare where you stand. The community will validate through your work.',
    type:'rank-select',
    options:[
      {icon:'🪃',name:'Psilos',desc:'Just beginning — curious and eager'},
      {icon:'🛡️',name:'Hoplite',desc:'Know the basics, built a few things'},
      {icon:'🐎',name:'Hippeis',desc:'Comfortable, have shipped projects'},
      {icon:'🏹',name:'Ouragos',desc:'Led teams, consistent builder'},
      {icon:'⚔️',name:'Lochagos',desc:'Mentors others, deep technical skill'},
      {icon:'🗡️',name:'Taxiarch',desc:'Community pillar, prolific builder'},
    ],
    featureHint:{icon:'⚔️',text:'<strong>Military Progression</strong> — Your rank is a living signal of consistency. It grows through commits, reviews, blogs, and peer validation — not self-declaration alone.'}
  },
  {
    id:'why',
    glyph:'🔥',
    num:'07',
    question:'Why are you <em>entering the forge</em>?',
    hint:'What brings you to TROVE? Select all that apply to you.',
    type:'multi-chips',
    options:['Build a real portfolio','Find serious teammates','Prove my technical skills','Get internship / job','Build in public','Join builder community','Win hackathons','All of the above'],
    featureHint:{icon:'🎯',text:'<strong>Smart Matching</strong> — Your goals shape the AI teammate matching algorithm in The Beacon and opportunity recommendations.'}
  },
  {
    id:'builds',
    glyph:'🧱',
    num:'08',
    question:'Tell us about your <em>proudest build</em>.',
    hint:'One project you shipped — what it was, what you learned. Be honest, even if small.',
    type:'textarea',
    placeholder:'I built a... it taught me...',
    featureHint:{icon:'📜',text:'<strong>The Codex</strong> — Your first dev log entry. These build stories become your public engineering narrative on your profile.'}
  },
  {
    id:'github',
    glyph:'🐙',
    num:'09',
    question:"What's your <em>GitHub handle</em>?",
    hint:'We pull your public activity to power the Activity Matrix on your profile.',
    type:'text',
    placeholder:'github.com/your-handle',
    featureHint:{icon:'📡',text:'<strong>Activity Matrix</strong> — GitHub commits light up your daily builder matrix, the most visible part of your Identity Card.'}
  },
  {
    id:'linkedin',
    glyph:'💼',
    num:'10',
    question:"Your <em>LinkedIn URL</em> — optional but powerful.",
    hint:'Syncs professional credibility with your builder identity on TROVE.',
    type:'text',
    placeholder:'linkedin.com/in/yourname',
    featureHint:{icon:'🧬',text:'<strong>Cross-Platform Identity</strong> — LinkedIn data enriches your Identity Card and helps recruiters verify your TROVE rank.'}
  },
  {
    id:'discovered',
    glyph:'🗺️',
    num:'11',
    question:'How did you <em>discover the forge</em>?',
    hint:'Helps us understand where builders come from.',
    type:'chips',
    options:['Friend / Classmate','LinkedIn','Twitter / X','Instagram','Discord / Reddit','College Club','Faculty / Professor','Hackathon','Just exploring','Other'],
    featureHint:{icon:'📊',text:'<strong>Community Analytics</strong> — Anonymous discovery data helps us grow the builder community more effectively.'}
  },
  {
    id:'commit',
    glyph:'⚡',
    num:'12',
    question:'Make your <em>builder oath</em>.',
    hint:'How consistently will you show up? This sets your starting Activity Matrix target.',
    type:'chips',
    options:['Daily builder','3–4x per week','Weekends only','Project-driven','Whenever inspired','ALL IN — no mercy'],
    featureHint:{icon:'📡',text:'<strong>Activity Matrix</strong> — Your consistency pledge is your first public commitment. The matrix tracks every day you show up.'}
  }
];

/* ═══════════════════ SCREEN MANAGEMENT ═══════════════════ */
function goToScreen(name) {
  const all = document.querySelectorAll('.screen');
  const target = document.getElementById('screen-' + name);
  const current = document.querySelector('.screen.active');

  if (current) {
    current.classList.remove('active');
    current.classList.add('exit-up');
    setTimeout(() => current.classList.remove('exit-up'), 500);
  }

  setTimeout(() => {
    if (target) {
      target.classList.add('active');
      target.querySelector('input,textarea,button')?.focus?.();
    }
  }, 100);

  currentScreen = name;

  if (name === 'onboard') {
    buildProgress();
    renderStep(0);
  }
}

/* ═══════════════════ BUILD PROGRESS BAR ═══════════════════ */
function buildProgress() {
  const container = document.getElementById('runeProgress');
  container.innerHTML = '';
  STEPS.forEach((s, i) => {
    const pip = document.createElement('div');
    pip.className = 'rune-pip';
    pip.textContent = s.num;
    pip.id = 'pip-' + i;
    pip.onclick = () => { if (i <= currentStep) jumpToStep(i); };
    container.appendChild(pip);
    if (i < STEPS.length - 1) {
      const line = document.createElement('div');
      line.className = 'rune-line';
      line.id = 'line-' + i;
      container.appendChild(line);
    }
  });
  updateProgress();
}

function updateProgress() {
  STEPS.forEach((s, i) => {
    const pip = document.getElementById('pip-' + i);
    if (!pip) return;
    pip.classList.remove('active','completed');
    if (i < currentStep) pip.classList.add('completed');
    else if (i === currentStep) pip.classList.add('active');

    const line = document.getElementById('line-' + i);
    if (line) {
      line.classList.toggle('filled', i < currentStep);
    }
  });
}

/* ═══════════════════ RENDER STEP ═══════════════════ */
function renderStep(idx, direction = 'right') {
  const step = STEPS[idx];
  const container = document.getElementById('stepContainer');

  // Exit old content
  const old = container.querySelector('.step-content.active');
  if (old) {
    old.classList.remove('active');
    old.classList.add(direction === 'right' ? 'exit-left' : 'exit-right');
    setTimeout(() => old.remove(), 300);
  }

  const div = document.createElement('div');
  div.className = 'step-content';
  div.dataset.stepId = step.id;

  let inputHTML = '';
  if (step.type === 'text') {
    inputHTML = `<input class="step-input" id="si-${step.id}" type="text" placeholder="${step.placeholder}" value="${answers[step.id]||''}" oninput="answers['${step.id}']=this.value" onkeydown="handleKeyDown(event)"/>`;
  } else if (step.type === 'textarea') {
    const val = answers[step.id]||'';
    inputHTML = `
      <textarea class="step-textarea" id="si-${step.id}" maxlength="280" placeholder="${step.placeholder}" oninput="answers['${step.id}']=this.value;updateCharCount(this)">${val}</textarea>
      <div class="char-count" id="cc-${step.id}">${val.length}/280</div>
    `;
  } else if (step.type === 'chips') {
    const chips = step.options.map(o =>
      `<div class="chip${answers[step.id]===o?' selected':''}" onclick="selectChip(this,'${step.id}','${o}')"><span>${o}</span></div>`
    ).join('');
    inputHTML = `<div class="chip-grid">${chips}</div>`;
  } else if (step.type === 'multi-chips') {
    const selected = answers[step.id]||[];
    const chips = step.options.map(o =>
      `<div class="chip multi${selected.includes(o)?' selected':''}" onclick="toggleChip(this,'${step.id}','${o}')"><span>${o}</span></div>`
    ).join('');
    inputHTML = `<div class="chip-grid">${chips}</div>`;
  } else if (step.type === 'rank-select') {
    const cards = step.options.map(o =>
      `<div class="rank-sel-card${answers[step.id]===o.name?' selected':''}" onclick="selectRank(this,'${step.id}','${o.name}')">
        <div class="rsc-icon">${o.icon}</div>
        <div class="rsc-name">${o.name}</div>
        <div class="rsc-desc">${o.desc}</div>
      </div>`
    ).join('');
    inputHTML = `<div class="rank-select-grid">${cards}</div>`;
  }

  const hint = step.featureHint
    ? `<div class="feature-hint"><span class="feature-hint-icon">${step.featureHint.icon}</span><div class="feature-hint-text">${step.featureHint.text}</div></div>`
    : '';

  div.innerHTML = `
    <div class="step-num">${step.num} / 12</div>
    <span class="step-glyph">${step.glyph}</span>
    <h2 class="step-question">${step.question}</h2>
    <p class="step-hint">${step.hint}</p>
    ${inputHTML}
    ${hint}
  `;

  container.appendChild(div);
  requestAnimationFrame(() => {
    requestAnimationFrame(() => { div.classList.add('active'); });
  });

  // Auto-focus text inputs
  if (step.type === 'text' || step.type === 'textarea') {
    setTimeout(() => document.getElementById('si-'+step.id)?.focus(), 400);
  }

  // Back button
  document.getElementById('backBtn').style.opacity = idx === 0 ? '.3' : '1';
  document.getElementById('backBtn').style.pointerEvents = idx === 0 ? 'none' : 'all';
}

/* ═══════════════════ STEP NAVIGATION ═══════════════════ */
function nextStep() {
  addRipple(document.getElementById('nextBtn'));
  if (currentStep < STEPS.length - 1) {
    currentStep++;
    updateProgress();
    renderStep(currentStep, 'right');
  } else {
    // Done — go to success
    goToScreen('success');
  }
}

function prevStep() {
  if (currentStep > 0) {
    addRipple(document.getElementById('backBtn'));
    currentStep--;
    updateProgress();
    renderStep(currentStep, 'left');
  }
}

function jumpToStep(idx) {
  if (idx === currentStep) return;
  const dir = idx > currentStep ? 'right' : 'left';
  currentStep = idx;
  updateProgress();
  renderStep(currentStep, dir);
}

/* ═══════════════════ INPUT HELPERS ═══════════════════ */
function selectChip(el, id, val) {
  answers[id] = val;
  el.closest('.chip-grid').querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  addRipple(el);
  // Auto-advance after brief delay
  setTimeout(nextStep, 400);
}

function toggleChip(el, id, val) {
  if (!answers[id]) answers[id] = [];
  const arr = answers[id];
  const idx = arr.indexOf(val);
  if (idx > -1) { arr.splice(idx, 1); el.classList.remove('selected'); }
  else { arr.push(val); el.classList.add('selected'); addRipple(el); }
}

function selectRank(el, id, val) {
  answers[id] = val;
  el.closest('.rank-select-grid').querySelectorAll('.rank-sel-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  addRipple(el);
  setTimeout(nextStep, 500);
}

function updateCharCount(el) {
  const id = el.id.replace('si-','');
  const cc = document.getElementById('cc-'+id);
  if (!cc) return;
  const n = el.value.length;
  cc.textContent = n + '/280';
  cc.className = 'char-count' + (n > 250 ? ' over' : n > 200 ? ' warn' : '');
}

function handleKeyDown(e) {
  if (e.key === 'Enter') { e.preventDefault(); nextStep(); }
}

/* ═══════════════════ KEYBOARD EVENTS ═══════════════════ */
document.addEventListener('keydown', e => {
  const keyEl = document.getElementById('keyEnter');
  if (e.key === 'Enter') {
    keyEl.classList.add('pressed');
    if (currentScreen === 'onboard') {
      const active = document.querySelector('.step-content.active');
      if (active) {
        const sid = active.dataset.stepId;
        const step = STEPS.find(s => s.id === sid);
        if (step && step.type === 'text') nextStep();
      }
    } else if (currentScreen === 'login') {
      handleLogin();
    } else if (currentScreen === 'signup') {
      handleSignup();
    }
    setTimeout(() => keyEl.classList.remove('pressed'), 200);
  }
  // Arrow key navigation
  if (currentScreen === 'onboard') {
    if (e.key === 'ArrowRight') nextStep();
    if (e.key === 'ArrowLeft') prevStep();
  }
});

/* ═══════════════════ AUTH HANDLERS ═══════════════════ */
function handleLogin() {
  const email = document.getElementById('loginEmail');
  const pw = document.getElementById('loginPw');
  let ok = true;
  if (!email.value.includes('@')) {
    email.classList.add('error'); document.getElementById('loginEmailErr').classList.add('show'); ok=false;
    setTimeout(()=>{email.classList.remove('error');},600);
  } else { email.classList.remove('error'); document.getElementById('loginEmailErr').classList.remove('show'); }
  if (!pw.value) {
    pw.classList.add('error'); document.getElementById('loginPwErr').classList.add('show'); ok=false;
    setTimeout(()=>{pw.classList.remove('error');},600);
  } else { pw.classList.remove('error'); document.getElementById('loginPwErr').classList.remove('show'); }
  if (ok) goToScreen('success');
}

function handleSignup() {
  const email = document.getElementById('signupEmail');
  const pw = document.getElementById('signupPw');
  let ok = true;
  if (!email.value.includes('@')) {
    email.classList.add('error'); document.getElementById('signupEmailErr').classList.add('show'); ok=false;
    setTimeout(()=>{email.classList.remove('error');},600);
  } else { email.classList.remove('error'); document.getElementById('signupEmailErr').classList.remove('show'); }
  if (!pw.value || pw.value.length < 6) {
    pw.classList.add('error'); ok=false;
    setTimeout(()=>{pw.classList.remove('error');},600);
  }
  if (ok) {
    // Store email and password in answers for later submission
    answers.email = email.value.trim();
    answers.password = pw.value;
    answers.username = email.value.split('@')[0]; // Generate username from email
    goToScreen('onboard');
  }
}

/* ═══════════════════ PASSWORD STRENGTH ═══════════════════ */
function updateStrength(val) {
  const segs = [document.getElementById('str1'),document.getElementById('str2'),document.getElementById('str3'),document.getElementById('str4')];
  segs.forEach(s=>{s.className='strength-seg';});
  if (!val) return;
  let score = 0;
  if (val.length >= 6) score++;
  if (val.length >= 10) score++;
  if (/[^a-zA-Z0-9]/.test(val)) score++;
  if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
  const cls = score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';
  for (let i=0;i<score;i++) segs[i].classList.add(cls);
}

/* Show/hide password */
document.getElementById('togglePw')?.addEventListener('click', ()=>{
