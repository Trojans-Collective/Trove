<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TROVE — Forge Your Identity</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
/* ══════════════════ TOKENS ══════════════════ */
:root {
  --c-black:#000000;--c-cyan:#92DCE5;--c-cream:#EEE5E9;
  --c-grey:#7C7C7C;--c-red:#D64933;
  --ease-out-expo:cubic-bezier(.16,1,.3,1);
  --ease-bounce:cubic-bezier(.34,1.56,.64,1);
}
[data-theme="dark"]{
  --bg:#000;--bg2:#080808;--surface:#111;--surface2:#1a1a1a;
  --border:rgba(146,220,229,.1);--border2:rgba(146,220,229,.2);
  --text:#EEE5E9;--text-muted:#7C7C7C;--text-dim:#444;
  --accent:#92DCE5;--accent2:#D64933;
  --glow:rgba(146,220,229,.15);--glow2:rgba(214,73,51,.15);
  --input-bg:#0d0d0d;--input-border:rgba(146,220,229,.15);
}
[data-theme="light"]{
  --bg:#EEE5E9;--bg2:#e4dade;--surface:#f5f0f2;--surface2:#fff;
  --border:rgba(0,0,0,.1);--border2:rgba(0,0,0,.2);
  --text:#000;--text-muted:#7C7C7C;--text-dim:#bbb;
  --accent:#1a7a85;--accent2:#D64933;
  --glow:rgba(0,120,130,.1);--glow2:rgba(214,73,51,.12);
  --input-bg:#fff;--input-border:rgba(0,100,110,.2);
}

/* ══════════════════ BASE ══════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{
  font-family:'Syne',sans-serif;
  background:var(--bg);
  color:var(--text);
  transition:background .6s,color .6s;
  overflow:hidden;
  user-select:none;
}

/* ══════════════════ CANVAS ══════════════════ */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* ══════════════════ CUSTOM CURSOR ══════════════════ */
.cursor{
  position:fixed;width:8px;height:8px;
  background:var(--accent);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:background .3s;
  mix-blend-mode:difference;
}
.cursor-ring{
  position:fixed;width:36px;height:36px;
  border:1.5px solid var(--accent);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  opacity:.5;
  transition:width .35s var(--ease-bounce),height .35s var(--ease-bounce),opacity .3s,border-color .3s;
}
.cursor-ring.expanded{width:60px;height:60px;opacity:.2;}
.cursor-ring.clicked{width:20px;height:20px;opacity:.8;}

/* ══════════════════ NAVBAR ══════════════════ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.2rem 2.5rem;
}
.nav::before{
  content:'';position:absolute;inset:0;
  background:var(--bg);opacity:.7;z-index:-1;
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.logo{
  font-family:'Bebas Neue',sans-serif;font-size:1.7rem;
  letter-spacing:.18em;color:var(--accent);text-decoration:none;
}
.logo span{color:var(--accent2);}

.nav-right{display:flex;align-items:center;gap:1.2rem;}

.nav-back{
  font-family:'DM Mono',monospace;font-size:.65rem;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--text-muted);text-decoration:none;
  border:1px solid var(--border);border-radius:3px;
  padding:.4rem .9rem;
  transition:color .3s,border-color .3s,transform .25s;
  cursor:pointer;background:transparent;
}
.nav-back:hover{color:var(--accent);border-color:var(--accent);transform:translateY(-1px);}

/* Theme toggle */
.theme-toggle{
  width:48px;height:26px;border-radius:99px;
  background:var(--surface2);border:1.5px solid var(--border);
  cursor:pointer;position:relative;overflow:hidden;
  transition:background .4s,border .4s;flex-shrink:0;
}
.theme-toggle::before{
  content:'';position:absolute;top:3px;left:3px;
  width:18px;height:18px;border-radius:50%;
  background:var(--accent);
  transition:transform .45s var(--ease-bounce),background .4s;
  box-shadow:0 0 8px var(--glow);
}
[data-theme="light"] .theme-toggle::before{transform:translateX(22px);background:var(--accent2);}
.theme-icon{position:absolute;top:50%;transform:translateY(-50%);font-size:.65rem;pointer-events:none;transition:opacity .3s;}
.icon-moon{left:6px;}.icon-sun{right:5px;opacity:0;}
[data-theme="light"] .icon-moon{opacity:0;}[data-theme="light"] .icon-sun{opacity:1;}

/* ══════════════════ SCREEN SYSTEM ══════════════════ */
.screen{
  position:fixed;inset:0;z-index:10;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .5s var(--ease-out-expo),transform .5s var(--ease-out-expo);
  transform:translateY(30px);
  overflow:hidden;
}
.screen.active{opacity:1;pointer-events:all;transform:translateY(0);}
.screen.exit-up{opacity:0;transform:translateY(-40px);}
.screen.exit-down{opacity:0;transform:translateY(40px);}

/* ══════════════════ AUTH SCREENS ══════════════════ */
.auth-wrap{
  position:relative;z-index:1;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;padding:2rem;
  width:100%;max-width:480px;
}

.auth-eyebrow{
  font-family:'DM Mono',monospace;font-size:.65rem;
  letter-spacing:.3em;text-transform:uppercase;
  color:var(--accent);
  border:1px solid var(--border2);border-radius:99px;
  padding:.3rem 1rem;margin-bottom:2rem;
  animation:pulseGlow 3s ease-in-out infinite;
}
@keyframes pulseGlow{
  0%,100%{box-shadow:0 0 0 rgba(146,220,229,0);}
  50%{box-shadow:0 0 20px var(--glow);}
}

.auth-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3.5rem,8vw,6rem);
  line-height:.9;letter-spacing:.04em;
  margin-bottom:1rem;
}
.auth-title .line2{color:var(--accent);}

.auth-sub{
  font-family:'Instrument Serif',serif;font-style:italic;
  font-size:1.05rem;color:var(--text-muted);
  margin-bottom:3rem;line-height:1.6;
}

.auth-btns{display:flex;flex-direction:column;gap:.9rem;width:100%;}

.btn-forge{
  padding:1rem 2rem;
  background:var(--accent);color:#000;
  font-family:'DM Mono',monospace;font-size:.78rem;
  letter-spacing:.14em;text-transform:uppercase;
  border:none;border-radius:3px;cursor:pointer;
  position:relative;overflow:hidden;
  transition:transform .25s var(--ease-bounce),box-shadow .25s;
  font-weight:500;
}
.btn-forge::before{
  content:'';position:absolute;inset:0;
  background:var(--accent2);transform:translateX(-101%);
  transition:transform .4s var(--ease-out-expo);
}
.btn-forge span{position:relative;z-index:1;}
.btn-forge:hover{transform:translateY(-3px);box-shadow:0 16px 40px var(--glow);}
.btn-forge:hover::before{transform:translateX(0);}
.btn-forge:active{transform:scale(.97);}

.btn-ghost{
  padding:1rem 2rem;background:transparent;
  color:var(--text);font-family:'DM Mono',monospace;
  font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;
  border:1.5px solid var(--border2);border-radius:3px;cursor:pointer;
  transition:border-color .3s,color .3s,transform .25s var(--ease-bounce);
}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px);}
.btn-ghost:active{transform:scale(.97);}

.auth-divider{
  display:flex;align-items:center;gap:1rem;
  font-family:'DM Mono',monospace;font-size:.6rem;
  letter-spacing:.2em;color:var(--text-dim);
  margin:.3rem 0;
}
.auth-divider::before,.auth-divider::after{
  content:'';flex:1;height:1px;background:var(--border);
}

/* ══════════════════ LOGIN FORM ══════════════════ */
.login-wrap{
  width:100%;max-width:440px;
  position:relative;z-index:1;
  padding:2rem;
}
.login-header{margin-bottom:2.5rem;text-align:center;}
.login-header h2{
  font-family:'Bebas Neue',sans-serif;font-size:3.5rem;
  letter-spacing:.08em;margin-bottom:.3rem;
}
.login-header p{
  font-family:'DM Mono',monospace;font-size:.65rem;
  letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted);
}

/* Input groups */
.input-group{position:relative;margin-bottom:1.3rem;}
.input-label{
  font-family:'DM Mono',monospace;font-size:.62rem;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--text-muted);margin-bottom:.5rem;display:block;
  transition:color .3s;
}
.input-field{
  width:100%;padding:.9rem 1.1rem;
  background:var(--input-bg);
  border:1.5px solid var(--input-border);
  border-radius:3px;
  color:var(--text);
  font-family:'DM Mono',monospace;font-size:.82rem;
  outline:none;
  transition:border-color .3s,box-shadow .3s,transform .2s;
}
.input-field::placeholder{color:var(--text-dim);}
.input-field:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--glow);
  transform:translateY(-1px);
}
.input-field:focus + .input-glow{opacity:1;}
.input-glow{
  position:absolute;inset:0;border-radius:3px;
  box-shadow:0 0 20px var(--glow);
  opacity:0;pointer-events:none;
  transition:opacity .3s;
}
.input-group:focus-within .input-label{color:var(--accent);}

/* Shake on error */
@keyframes shake{
  0%,100%{transform:translateX(0);}
  20%{transform:translateX(-6px);}
  40%{transform:translateX(6px);}
  60%{transform:translateX(-4px);}
  80%{transform:translateX(4px);}
}
.input-field.error{border-color:var(--accent2);animation:shake .4s ease;}
.error-msg{
  font-family:'DM Mono',monospace;font-size:.6rem;
  letter-spacing:.12em;color:var(--accent2);
  margin-top:.4rem;display:none;
}
.error-msg.show{display:block;}

.input-toggle-pw{
  position:absolute;right:.9rem;top:50%;
  transform:translateY(calc(-50% + 12px));
  cursor:pointer;color:var(--text-muted);font-size:.85rem;
  transition:color .3s;border:none;background:none;
}
.input-toggle-pw:hover{color:var(--accent);}

/* strength bar */
.strength-bar{
  display:flex;gap:3px;margin-top:.5rem;
}
.strength-seg{
  height:3px;flex:1;border-radius:99px;
  background:var(--border);transition:background .4s;
}
.strength-seg.weak{background:var(--accent2);}
.strength-seg.medium{background:#f0c040;}
.strength-seg.strong{background:var(--accent);}

/* ══════════════════ ONBOARDING SYSTEM ══════════════════ */
.onboard-wrap{
  position:relative;z-index:1;
  width:100%;max-width:600px;
  padding:2rem;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
}

/* Progress rune bar */
.rune-progress{
  display:flex;align-items:center;gap:.5rem;
  margin-bottom:3rem;
}
.rune-pip{
  width:28px;height:28px;border-radius:50%;
  border:1.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Mono',monospace;font-size:.55rem;
  color:var(--text-dim);
  position:relative;cursor:pointer;
  transition:all .4s var(--ease-bounce);
  background:var(--surface);
}
.rune-pip.completed{
  background:var(--accent);border-color:var(--accent);
  color:#000;transform:scale(1.05);
}
.rune-pip.active{
  border-color:var(--accent);color:var(--accent);
  box-shadow:0 0 0 4px var(--glow),0 0 20px var(--glow);
  animation:ripplePip 2s ease-in-out infinite;
}
@keyframes ripplePip{
  0%,100%{box-shadow:0 0 0 4px var(--glow),0 0 20px var(--glow);}
  50%{box-shadow:0 0 0 8px rgba(146,220,229,.05),0 0 30px var(--glow);}
}
.rune-line{height:1px;flex:1;background:var(--border);position:relative;overflow:hidden;}
.rune-line::after{
  content:'';position:absolute;inset:0;
  background:var(--accent);transform:scaleX(0);transform-origin:left;
  transition:transform .6s var(--ease-out-expo);
}
.rune-line.filled::after{transform:scaleX(1);}

/* Step question */
.step-num{
  font-family:'DM Mono',monospace;font-size:.62rem;
  letter-spacing:.3em;text-transform:uppercase;
  color:var(--accent2);margin-bottom:.8rem;
  display:flex;align-items:center;gap:.6rem;
}
.step-num::before,.step-num::after{content:'—';}

.step-glyph{
  font-size:3rem;margin-bottom:1rem;
  display:block;
  animation:floatGlyph 4s ease-in-out infinite;
}
@keyframes floatGlyph{
  0%,100%{transform:translateY(0) rotate(-3deg);}
  50%{transform:translateY(-10px) rotate(3deg);}
}

.step-question{
  font-family:'Instrument Serif',serif;
  font-size:clamp(1.6rem,4vw,2.4rem);
  line-height:1.2;margin-bottom:.6rem;
  color:var(--text);
}
.step-question em{color:var(--accent);font-style:italic;}

.step-hint{
  font-family:'DM Mono',monospace;font-size:.68rem;
  letter-spacing:.12em;color:var(--text-muted);
  margin-bottom:2.2rem;line-height:1.6;
}

/* Choice chips */
.chip-grid{
  display:flex;flex-wrap:wrap;gap:.6rem;
  justify-content:center;margin-bottom:2rem;
}
.chip{
  padding:.5rem 1.1rem;
  border:1.5px solid var(--border2);border-radius:3px;
  font-family:'DM Mono',monospace;font-size:.68rem;
  letter-spacing:.12em;text-transform:uppercase;
  color:var(--text-muted);cursor:pointer;
  background:var(--surface);
  transition:all .25s var(--ease-bounce);
  position:relative;overflow:hidden;
}
.chip::before{
  content:'';position:absolute;inset:0;
  background:var(--accent);opacity:0;
  transition:opacity .25s;
}
.chip span{position:relative;z-index:1;}
.chip:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px);}
.chip.selected{
  border-color:var(--accent);color:#000;
  transform:translateY(-3px) scale(1.05);
  box-shadow:0 8px 24px var(--glow);
}
.chip.selected::before{opacity:1;}
.chip:active{transform:scale(.95);}

/* Multi-select chips */
.chip.multi.selected{color:#000;}
.chip.multi.selected::before{background:var(--accent);}

/* Rank selector cards */
.rank-select-grid{
  display:grid;grid-template-columns:repeat(2,1fr);
  gap:.8rem;width:100%;margin-bottom:2rem;
  max-height:320px;overflow-y:auto;
  scrollbar-width:thin;scrollbar-color:var(--border) transparent;
}
.rank-sel-card{
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:4px;padding:1rem;
  display:flex;flex-direction:column;align-items:flex-start;
  cursor:pointer;text-align:left;
  transition:all .3s var(--ease-bounce);position:relative;overflow:hidden;
}
.rank-sel-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;
  height:2px;background:var(--accent);
  transform:scaleX(0);transform-origin:left;
  transition:transform .3s;
}
.rank-sel-card:hover{border-color:var(--accent);transform:translateY(-3px);}
.rank-sel-card:hover::after{transform:scaleX(1);}
.rank-sel-card.selected{
  border-color:var(--accent);background:var(--surface2);
  box-shadow:0 8px 24px var(--glow);
}
.rank-sel-card.selected::after{transform:scaleX(1);}
.rsc-icon{font-size:1.5rem;margin-bottom:.4rem;}
.rsc-name{
  font-family:'Bebas Neue',sans-serif;font-size:1.1rem;
  letter-spacing:.1em;color:var(--text);
}
.rsc-desc{
  font-family:'DM Mono',monospace;font-size:.6rem;
  letter-spacing:.1em;color:var(--text-muted);margin-top:.2rem;
  line-height:1.5;
}

/* Textarea */
.step-textarea{
  width:100%;padding:1rem 1.2rem;
  background:var(--input-bg);
  border:1.5px solid var(--input-border);
  border-radius:3px;
  color:var(--text);font-family:'Instrument Serif',serif;
  font-size:1rem;line-height:1.7;
  outline:none;resize:none;height:120px;
  transition:border-color .3s,box-shadow .3s;
  margin-bottom:2rem;
}
.step-textarea::placeholder{color:var(--text-dim);font-style:italic;}
.step-textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow);}

/* Step input */
.step-input{
  width:100%;padding:1rem 1.2rem;
  background:var(--input-bg);
  border:1.5px solid var(--input-border);
  border-radius:3px;
  color:var(--text);font-family:'DM Mono',monospace;
  font-size:.9rem;letter-spacing:.08em;
  outline:none;margin-bottom:2rem;
  transition:border-color .3s,box-shadow .3s,transform .2s;
  text-align:center;
}
.step-input::placeholder{color:var(--text-dim);}
.step-input:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--glow);
  transform:scale(1.01);
}

/* Navigation arrows */
.step-nav{
  display:flex;align-items:center;gap:1.2rem;
}
.nav-arrow{
  width:52px;height:52px;border-radius:50%;
  border:1.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;background:var(--surface);
  color:var(--text-muted);font-size:1.1rem;
  transition:all .3s var(--ease-bounce);position:relative;overflow:hidden;
}
.nav-arrow::before{
  content:'';position:absolute;inset:0;border-radius:50%;
  background:var(--accent);opacity:0;
  transition:opacity .3s;
}
.nav-arrow span{position:relative;z-index:1;}
.nav-arrow:hover{
  border-color:var(--accent);color:#000;
  transform:translateY(-3px) scale(1.08);
  box-shadow:0 12px 30px var(--glow);
}
.nav-arrow:hover::before{opacity:1;}
.nav-arrow:active{transform:scale(.92);}
.nav-arrow.back-arrow{opacity:.5;}
.nav-arrow.back-arrow:hover{opacity:1;background:var(--surface2);}
.nav-arrow.back-arrow:hover::before{opacity:0;}
.nav-arrow.back-arrow:hover{color:var(--text);}

.skip-link{
  font-family:'DM Mono',monospace;font-size:.6rem;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--text-dim);cursor:pointer;
  text-decoration:none;
  transition:color .3s;
}
.skip-link:hover{color:var(--text-muted);}

/* ══════════════════ SLIDE TRANSITIONS ══════════════════ */
.step-content{
  opacity:0;transform:translateX(40px);
  transition:opacity .45s var(--ease-out-expo),transform .45s var(--ease-out-expo);
  width:100%;
}
.step-content.active{opacity:1;transform:translateX(0);}
.step-content.exit-left{opacity:0;transform:translateX(-40px);transition-duration:.25s;}
.step-content.exit-right{opacity:0;transform:translateX(40px);transition-duration:.25s;}

/* ══════════════════ CHAR COUNTER ══════════════════ */
.char-count{
  font-family:'DM Mono',monospace;font-size:.58rem;
  letter-spacing:.15em;color:var(--text-dim);
  text-align:right;margin-top:-.25rem;margin-bottom:1.5rem;
}
.char-count.warn{color:#f0c040;}
.char-count.over{color:var(--accent2);}

/* ══════════════════ FEATURE TOOLTIP ══════════════════ */
.feature-hint{
  display:flex;align-items:flex-start;gap:.8rem;
  background:var(--surface);
  border:1px solid var(--border);border-radius:4px;
  padding:.9rem 1.1rem;margin-top:1rem;
  text-align:left;
  animation:slideHint .4s var(--ease-out-expo) forwards;
  opacity:0;
}
@keyframes slideHint{to{opacity:1;transform:translateY(0);}
from{opacity:0;transform:translateY(8px);}}
.feature-hint-icon{font-size:1.2rem;flex-shrink:0;}
.feature-hint-text{
  font-family:'DM Mono',monospace;font-size:.62rem;
  letter-spacing:.08em;color:var(--text-muted);line-height:1.6;
}
.feature-hint-text strong{color:var(--accent);font-weight:500;}

/* ══════════════════ RANK BADGE REVEAL ══════════════════ */
.rank-badge{
  display:inline-flex;align-items:center;gap:.6rem;
  background:var(--surface);border:1.5px solid var(--accent);
  border-radius:4px;padding:.6rem 1.2rem;
  font-family:'Bebas Neue',sans-serif;font-size:1.2rem;
  letter-spacing:.14em;color:var(--accent);
  box-shadow:0 0 24px var(--glow);
  animation:badgePop .6s var(--ease-bounce);
}
@keyframes badgePop{
  from{transform:scale(0) rotate(-10deg);}
  to{transform:scale(1) rotate(0);}
}

/* ══════════════════ SUCCESS SCREEN ══════════════════ */
.success-wrap{
  position:relative;z-index:1;
  text-align:center;padding:2rem;
  max-width:500px;width:100%;
}
.success-glyph{
  font-size:5rem;display:block;
  animation:successBounce 1s var(--ease-bounce) .2s both;
}
@keyframes successBounce{
  from{transform:scale(0) rotate(-20deg);opacity:0;}
  to{transform:scale(1) rotate(0);opacity:1;}
}
.success-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3rem,8vw,5.5rem);
  line-height:.9;letter-spacing:.04em;
  margin:1rem 0;
  animation:fadeUp .7s var(--ease-out-expo) .5s both;
}
.success-sub{
  font-family:'Instrument Serif',serif;
  font-style:italic;font-size:1.1rem;
  color:var(--text-muted);line-height:1.7;
  margin-bottom:2.5rem;
  animation:fadeUp .7s var(--ease-out-expo) .7s both;
}
.success-rank{
  margin-bottom:2.5rem;
  animation:fadeUp .7s var(--ease-out-expo) .9s both;
}

/* ══════════════════ AMBIENT PARTICLES ══════════════════ */
.ambient-particle{
  position:fixed;border-radius:50%;
  pointer-events:none;z-index:1;
  animation:ambientFloat linear infinite;
  opacity:0;
}
@keyframes ambientFloat{
  0%{transform:translateY(0) scale(1);opacity:0;}
  10%{opacity:.4;}
  90%{opacity:.2;}
  100%{transform:translateY(-100vh) scale(.3);opacity:0;}
}

/* ══════════════════ KEY ANIMATIONS ══════════════════ */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}

/* ══════════════════ KEYBOARD HINT ══════════════════ */
.keyboard-hint{
  position:fixed;bottom:2rem;right:2rem;z-index:50;
  font-family:'DM Mono',monospace;font-size:.58rem;
  letter-spacing:.15em;color:var(--text-dim);
  display:flex;align-items:center;gap:.5rem;
  animation:fadeIn 1s 2s both;
}
.key-badge{
  border:1px solid var(--border);border-radius:3px;
  padding:.2rem .5rem;color:var(--text-muted);
  font-size:.6rem;background:var(--surface);
  transition:background .15s,transform .15s;
}
.key-badge.pressed{
  background:var(--accent);color:#000;
  transform:scale(.9);
}

/* ══════════════════ FIELD ANIM ══════════════════ */
@keyframes inputSuccess{
  0%{border-color:var(--accent);}
  50%{box-shadow:0 0 0 6px var(--glow);}
  100%{border-color:var(--accent);}
}
.input-success{animation:inputSuccess .5s ease;}

/* ripple */
.ripple{
  position:absolute;border-radius:50%;
  background:rgba(146,220,229,.2);
  transform:scale(0);
  animation:rippleAnim .6s linear;
  pointer-events:none;
}
@keyframes rippleAnim{to{transform:scale(4);opacity:0;}}

/* ══════════════════ SCROLL BAR ══════════════════ */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* ══════════════════ MOBILE ══════════════════ */
@media(max-width:640px){
  .nav{padding:1rem 1.2rem;}
  .rank-select-grid{grid-template-columns:1fr;}
  .onboard-wrap{padding:1rem;}
  .step-question{font-size:1.5rem;}
}
</style>
</head>
<body>

