/* ═══════════════════ 3D CANVAS ═══════════════════ */
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, scrollOff = 0;

function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
window.addEventListener('resize', resize); resize();

function getColors() {
  return html.getAttribute('data-theme') === 'dark'
    ? {p:'rgba(146,220,229,', l:'rgba(146,220,229,', g:'rgba(146,220,229,'}
    : {p:'rgba(0,110,120,', l:'rgba(0,110,120,', g:'rgba(0,100,110,'};
}
let colCache = getColors();
function updateCanvasColors() { colCache = getColors(); }

// Particles
class Particle {
  constructor() { this.reset(true); }
  reset(init=false) {
    this.x = Math.random() * W;
    this.y = init ? Math.random() * H : H + 20;
    this.z = Math.random() * 500 + 100;
    this.vx = (Math.random()-.5) * .2;
    this.vy = -Math.random() * .35 - .08;
    this.r  = Math.random() * 1.4 + .4;
    this.a  = Math.random() * .5 + .1;
    this.life = 0; this.maxLife = Math.random()*500+200;
  }
  update() {
    this.x += this.vx + (mx/W-.5)*.06;
    this.y += this.vy + (my/H-.5)*.04;
    this.z += (Math.random()-.5)*.3;
    this.life++;
    const fov = 400, scale = fov/(fov+this.z);
    this.sx = (this.x-W/2)*scale+W/2;
    this.sy = (this.y-H/2)*scale+H/2;
    this.sr = this.r * scale;
    this.sa = this.a * Math.min(this.life/60,1) * (1-this.life/this.maxLife);
    if (this.y<-20||this.life>this.maxLife) this.reset();
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.sx,this.sy,Math.max(.1,this.sr),0,Math.PI*2);
    ctx.fillStyle = colCache.p + this.sa + ')';
    ctx.fill();
  }
}

const PCOUNT = 80;
let particles = Array.from({length:PCOUNT},()=>new Particle());

function drawGrid() {
  const horizon = H*.5;
  ctx.save();
  for (let i=-12;i<=12;i++) {
    const wx = i*90, x1=W/2+wx, factor=H/(H-horizon);
    const x2=W/2+wx*factor*2.5, y2=H;
    const a = Math.max(0,.1-Math.abs(i)*.007);
    ctx.beginPath();ctx.moveTo(x1,horizon);ctx.lineTo(x2,y2);
    ctx.strokeStyle=colCache.g+a+')';ctx.lineWidth=.6;ctx.stroke();
  }
  for (let j=0;j<=8;j++) {
    const t=j/8, y=horizon+(H-horizon)*Math.pow(t,1.6);
    const spread=180+(y-horizon)/(H-horizon)*W*1.2;
    ctx.beginPath();ctx.moveTo(W/2-spread,y);ctx.lineTo(W/2+spread,y);
    ctx.strokeStyle=colCache.g+(t*.1)+')';ctx.lineWidth=.6;ctx.stroke();
  }
  ctx.restore();
}

function drawConnections() {
  for (let i=0;i<particles.length;i++) {
    for (let j=i+1;j<particles.length;j++) {
      const p1=particles[i],p2=particles[j];
      const dx=p1.sx-p2.sx,dy=p1.sy-p2.sy;
      const d=Math.sqrt(dx*dx+dy*dy);
      if (d<80) {
        ctx.beginPath();ctx.moveTo(p1.sx,p1.sy);ctx.lineTo(p2.sx,p2.sy);
        ctx.strokeStyle=colCache.l+(1-d/80)*.08+')';ctx.lineWidth=.5;ctx.stroke();
      }
    }
  }
}

// Floating glyphs on canvas
const GLYPHS = ['⚔','🛡','🏹','⚡','🔥','🗡','🏛','🎯'];
class FloatingGlyph {
  constructor() { this.reset(); }
  reset() {
    this.x=Math.random()*W; this.y=H+50;
    this.vy=-Math.random()*.4-.1;
    this.alpha=0; this.size=Math.random()*14+10;
    this.glyph=GLYPHS[Math.floor(Math.random()*GLYPHS.length)];
    this.life=0; this.maxLife=Math.random()*600+300;
    this.drift=(Math.random()-.5)*.2;
  }
  update() {
    this.y+=this.vy; this.x+=this.drift; this.life++;
    this.alpha=Math.min(this.life/80,.12)*(1-this.life/this.maxLife);
    if (this.life>this.maxLife) this.reset();
  }
  draw() {
    ctx.save();ctx.globalAlpha=this.alpha;
    ctx.font=this.size+'px serif';ctx.textAlign='center';
    ctx.fillText(this.glyph,this.x,this.y);ctx.restore();
  }
}
const glyphs = Array.from({length:8},()=>new FloatingGlyph());
glyphs.forEach((g,i)=>{ g.y=Math.random()*H; g.life=Math.random()*g.maxLife; });

function animate() {
  ctx.clearRect(0,0,W,H);
  drawGrid();
  drawConnections();
  particles.forEach(p=>{p.update();p.draw();});
  glyphs.forEach(g=>{g.update();g.draw();});
  requestAnimationFrame(animate);
}
animate();

/* ═══════════════════ AMBIENT PARTICLES (DOM) ═══════════════════ */
