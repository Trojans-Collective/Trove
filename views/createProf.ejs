/* ═══════════════════ PROFILE SUBMISSION ═══════════════════ */
function submitProfile() {
  // Validate all required fields are filled
  const required = ['name', 'college', 'year', 'domain', 'experience', 'rank', 'why', 'builds', 'github', 'discovered', 'commit'];
  const missing = required.filter(field => !answers[field]);
  
  if (missing.length > 0) {
    alert('Please complete all required fields before submitting.');
    return;
  }

  // Prepare form data for submission
  const formData = new FormData();
  formData.append('email', answers.email);
  formData.append('password', answers.password);
  formData.append('username', answers.username);
  formData.append('name', answers.name);
  formData.append('college', answers.college);
  formData.append('year', answers.year);
  formData.append('experience', answers.experience);
  formData.append('rank', answers.rank);
  formData.append('builds', answers.builds);
  formData.append('github', answers.github);
  formData.append('linkedin', answers.linkedin || '');
  formData.append('discovered', answers.discovered);
  formData.append('commit', answers.commit);
  
  // Handle multi-select arrays (domain and why)
  if (Array.isArray(answers.domain)) {
    answers.domain.forEach(d => formData.append('domain', d));
  } else {
    formData.append('domain', answers.domain);
  }
  
  if (Array.isArray(answers.why)) {
    answers.why.forEach(w => formData.append('why', w));
  } else {
    formData.append('why', answers.why);
  }

  // Submit to backend
  fetch('/complete-onboarding', {
    method: 'POST',
    body: formData
  })
  .then(res => {
    if (res.ok) {
      window.location.href = '/home';
    } else {
      return res.json().then(data => {
        alert('Error: ' + (data.error || 'Failed to save profile'));
      });
    }
  })
  .catch(err => {
    console.error('Submission error:', err);
    alert('Failed to save profile. Please try again.');
  });
}
</script>
