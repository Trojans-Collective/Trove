<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TROVE — Proof of Work for Student Builders</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ─────────────────────── TOKENS ─────────────────────── */
    :root {
      --c-black:   #000000;
      --c-cyan:    #92DCE5;
      --c-cream:   #EEE5E9;
      --c-grey:    #7C7C7C;
      --c-red:     #D64933;
      --transition: 0.7s cubic-bezier(.77,0,.18,1);
    }

    [data-theme="dark"] {
      --bg:        #000000;
      --bg2:       #0a0a0a;
      --surface:   #111111;
      --surface2:  #1a1a1a;
      --border:    rgba(146,220,229,.12);
      --text:      #EEE5E9;
      --text-muted:#7C7C7C;
      --accent:    #92DCE5;
      --accent2:   #D64933;
      --glow:      rgba(146,220,229,.18);
    }

    [data-theme="light"] {
      --bg:        #EEE5E9;
      --bg2:       #e4dade;
      --surface:   #f5f0f2;
      --surface2:  #ffffff;
      --border:    rgba(0,0,0,.1);
      --text:      #000000;
      --text-muted:#7C7C7C;
      --accent:    #1a7a85;
      --accent2:   #D64933;
      --glow:      rgba(0,0,0,.06);
    }

    /* ─────────────────────── RESET ─────────────────────── */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      transition: background var(--transition), color var(--transition);
    }

    /* ─────────────────────── CANVAS ─────────────────────── */
    #bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ─────────────────────── NAVBAR ─────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 3rem;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      transition: background var(--transition);
    }
    nav::before {
      content:'';
      position:absolute;
      inset:0;
      background: var(--bg);
      opacity: .7;
      z-index:-1;
    }

    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: .18em;
      color: var(--accent);
      text-decoration: none;
      position: relative;
    }
    .logo span { color: var(--accent2); }

    .nav-links {
      display: flex;
      gap: 2.4rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: .75rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color .3s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* Theme toggle */
    .theme-toggle {
      width: 52px;
      height: 28px;
      border-radius: 99px;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: background .4s, border .4s;
      flex-shrink: 0;
    }
    .theme-toggle::before {
      content: '';
      position: absolute;
      top: 3px; left: 3px;
      width: 20px; height: 20px;
      border-radius: 50%;
      background: var(--accent);
      transition: transform .45s cubic-bezier(.34,1.56,.64,1), background .4s;
      box-shadow: 0 0 8px var(--glow);
    }
    [data-theme="light"] .theme-toggle::before {
      transform: translateX(24px);
      background: var(--accent2);
    }
    .theme-icon {
      position: absolute;
      top: 50%; transform: translateY(-50%);
      font-size: .7rem;
      pointer-events: none;
      transition: opacity .3s;
    }
    .icon-moon { left: 7px; }
    .icon-sun  { right: 6px; opacity: 0; }
    [data-theme="light"] .icon-moon { opacity: 0; }
    [data-theme="light"] .icon-sun  { opacity: 1; }

    /* ─────────────────────── HERO ─────────────────────── */
    #hero {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
      overflow: hidden;
    }

    .hero-tag {
      font-family: 'DM Mono', monospace;
      font-size: .72rem;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--border);
      border-radius: 99px;
      padding: .35rem 1.1rem;
      margin-bottom: 2.2rem;
      opacity: 0;
      animation: fadeUp .8s .3s forwards;
      backdrop-filter: blur(8px);
    }

    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 14rem);
      line-height: .88;
      letter-spacing: -.01em;
      color: var(--text);
      opacity: 0;
      animation: fadeUp .9s .5s forwards;
    }
    .hero-title .highlight {
      color: var(--accent);
      display: inline-block;
      position: relative;
    }
    .hero-title .highlight::after {
      content: '';
      position: absolute;
      bottom: .06em; left: 0; right: 0;
      height: .04em;
      background: var(--accent2);
      transform: scaleX(0);
      transform-origin: left;
      animation: lineReveal 1s 1.6s forwards;
    }

    .hero-sub {
      font-family: 'Instrument Serif', serif;
      font-style: italic;
      font-size: clamp(1rem, 2.2vw, 1.5rem);
      color: var(--text-muted);
      margin-top: 1.4rem;
      max-width: 540px;
      opacity: 0;
      animation: fadeUp .8s .9s forwards;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      margin-top: 3rem;
      opacity: 0;
      animation: fadeUp .8s 1.1s forwards;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn-primary {
      padding: .85rem 2.4rem;
      background: var(--accent);
      color: var(--black, #000);
      font-family: 'DM Mono', monospace;
      font-size: .78rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      border: none;
      border-radius: 3px;
      cursor: pointer;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: transform .25s, box-shadow .25s;
      font-weight: 500;
    }
    .btn-primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent2);
      transform: translateX(-101%);
      transition: transform .4s cubic-bezier(.77,0,.18,1);
    }
    .btn-primary span { position: relative; z-index: 1; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px var(--glow); }
    .btn-primary:hover::before { transform: translateX(0); }

    .btn-outline {
      padding: .85rem 2.4rem;
      background: transparent;
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: .78rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      border: 1.5px solid var(--border);
      border-radius: 3px;
      cursor: pointer;
      text-decoration: none;
      transition: border-color .3s, color .3s, transform .25s;
    }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    /* floating rank badge */
    .hero-rank {
      position: absolute;
      bottom: 3rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: .6rem;
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      letter-spacing: .2em;
      color: var(--text-muted);
      opacity: 0;
      animation: fadeUp .6s 1.5s forwards;
    }
    .hero-rank::before, .hero-rank::after {
      content: '';
      width: 40px;
      height: 1px;
      background: var(--border);
    }

    /* scroll indicator */
    .scroll-indicator {
      position: absolute;
      bottom: 1.5rem;
      right: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .4rem;
      opacity: 0;
      animation: fadeIn 1s 2s forwards;
    }
    .scroll-indicator span {
      font-family: 'DM Mono', monospace;
      font-size: .6rem;
      letter-spacing: .18em;
      color: var(--text-muted);
      writing-mode: vertical-rl;
    }
    .scroll-line {
      width: 1px;
      height: 50px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      animation: scrollPulse 2s 2s infinite;
    }

    /* ─────────────────────── PROBLEM SECTION ─────────────────────── */
    .section {
      position: relative;
      z-index: 1;
      padding: 8rem 2rem;
    }

    .section-inner {
      max-width: 1180px;
      margin: 0 auto;
    }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: .68rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 1.2rem;
    }

    .section-heading {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: .95;
      letter-spacing: .02em;
      margin-bottom: 2rem;
    }

    /* fragmented grid */
    #problem { background: var(--bg2); }
    .frag-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      margin-top: 4rem;
    }
    .frag-item {
      background: var(--surface);
      padding: 2rem 1.8rem;
      position: relative;
      overflow: hidden;
      transition: background .3s;
    }
    .frag-item:hover { background: var(--surface2); }
    .frag-item::before {
      content: attr(data-platform);
      position: absolute;
      top: 1rem; right: 1.2rem;
      font-family: 'DM Mono', monospace;
      font-size: .62rem;
      letter-spacing: .15em;
      color: var(--text-muted);
      opacity: .4;
    }
    .frag-icon {
      font-size: 1.6rem;
      margin-bottom: .8rem;
      display: block;
    }
    .frag-name {
      font-family: 'Syne', sans-serif;
      font-size: .95rem;
      font-weight: 700;
      margin-bottom: .35rem;
    }
    .frag-desc {
      font-size: .78rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .frag-item.highlight-item {
      background: linear-gradient(135deg, var(--surface2), var(--surface));
      border: 1px solid var(--accent);
      box-shadow: inset 0 0 40px var(--glow);
    }
    .frag-item.highlight-item .frag-name { color: var(--accent); }

    /* ─────────────────────── RANKS SECTION ─────────────────────── */
    #ranks {
      background: var(--bg);
      overflow: hidden;
    }

    .ranks-container {
      display: flex;
      gap: 1rem;
      margin-top: 4rem;
      overflow-x: auto;
      padding-bottom: 1rem;
      scrollbar-width: none;
    }
    .ranks-container::-webkit-scrollbar { display: none; }

    .rank-card {
      flex: 0 0 200px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 2rem 1.4rem;
      position: relative;
      cursor: pointer;
      transition: transform .4s cubic-bezier(.34,1.56,.64,1), border-color .3s, box-shadow .3s;
      transform-style: preserve-3d;
    }
    .rank-card:hover {
      transform: translateY(-8px) rotateX(6deg);
      border-color: var(--accent);
      box-shadow: 0 24px 48px var(--glow), 0 0 0 1px var(--accent);
    }
    .rank-card.active {
      border-color: var(--accent2);
      box-shadow: 0 0 40px rgba(214,73,51,.2);
    }
    .rank-num {
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      color: var(--text-muted);
      letter-spacing: .18em;
      margin-bottom: 1rem;
    }
    .rank-glyph {
      font-size: 2.2rem;
      margin-bottom: .8rem;
      display: block;
    }
    .rank-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: .12em;
      color: var(--text);
      margin-bottom: .3rem;
    }
    .rank-sub {
      font-size: .7rem;
      color: var(--text-muted);
      font-style: italic;
    }
    .rank-bar {
      position: absolute;
      bottom: 0; left: 0;
      height: 3px;
      background: var(--accent);
      transition: width .6s ease;
    }
    .rank-card:nth-child(1) .rank-bar { width: 12%; }
    .rank-card:nth-child(2) .rank-bar { width: 26%; }
    .rank-card:nth-child(3) .rank-bar { width: 40%; }
    .rank-card:nth-child(4) .rank-bar { width: 54%; }
    .rank-card:nth-child(5) .rank-bar { width: 67%; }
    .rank-card:nth-child(6) .rank-bar { width: 80%; }
    .rank-card:nth-child(7) .rank-bar { width: 92%; }
    .rank-card:nth-child(8) .rank-bar { width: 100%; background: var(--accent2); }

    /* ─────────────────────── FEATURES ─────────────────────── */
    #features { background: var(--bg2); }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
      background: var(--border);
      border: 1px solid var(--border);
      margin-top: 4rem;
    }

    .feat-card {
      background: var(--surface);
      padding: 3rem 2.5rem;
      position: relative;
      overflow: hidden;
      transition: background .3s;
    }
    .feat-card:hover { background: var(--surface2); }
    .feat-card.large {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 3rem;
    }
    .feat-num {
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      letter-spacing: .2em;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
    }
    .feat-icon {
      font-size: 2.2rem;
      margin-bottom: 1.2rem;
      display: block;
    }
    .feat-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: .8rem;
    }
    .feat-title span { color: var(--accent); }
    .feat-desc {
      font-size: .82rem;
      line-height: 1.8;
      color: var(--text-muted);
    }
    .feat-card::after {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(to right, var(--accent), transparent);
      opacity: 0;
      transition: opacity .3s;
    }
    .feat-card:hover::after { opacity: 1; }

    /* activity matrix preview */
    .matrix-preview {
      display: grid;
      grid-template-columns: repeat(20, 1fr);
      gap: 3px;
      margin-top: 1rem;
    }
    .matrix-dot {
      aspect-ratio: 1;
      border-radius: 2px;
      background: var(--surface2);
      border: 1px solid var(--border);
      transition: background .2s, transform .2s;
    }
    .matrix-dot.active-1 { background: rgba(146,220,229,.2); }
    .matrix-dot.active-2 { background: rgba(146,220,229,.45); }
    .matrix-dot.active-3 { background: rgba(146,220,229,.7); }
    .matrix-dot.active-4 { background: #92DCE5; box-shadow: 0 0 6px rgba(146,220,229,.4); }
    .matrix-dot:hover { transform: scale(1.5); background: var(--accent2) !important; }

    /* ─────────────────────── STATS ─────────────────────── */
    #stats {
      background: var(--bg);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      max-width: 1180px;
      margin: 0 auto;
    }
    .stat-item {
      padding: 3.5rem 2rem;
      border-right: 1px solid var(--border);
      text-align: center;
      position: relative;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4.5rem;
      letter-spacing: .04em;
      color: var(--accent);
      line-height: 1;
      display: block;
    }
    .stat-label {
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: .5rem;
    }

    /* ─────────────────────── CODEX / BLOG ─────────────────────── */
    #codex { background: var(--bg2); }
    .codex-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3.5rem;
    }
    .codex-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      cursor: pointer;
      transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s;
    }
    .codex-card:hover {
      transform: translateY(-6px) rotateX(3deg) rotateY(-2deg);
      box-shadow: 0 20px 48px var(--glow);
    }
    .codex-top {
      padding: 1.8rem;
      border-bottom: 1px solid var(--border);
    }
    .codex-tag {
      font-family: 'DM Mono', monospace;
      font-size: .6rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: .8rem;
    }
    .codex-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1.15rem;
      line-height: 1.4;
      margin-bottom: .6rem;
    }
    .codex-excerpt {
      font-size: .75rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .codex-bottom {
      padding: 1rem 1.8rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .codex-author {
      font-family: 'DM Mono', monospace;
      font-size: .6rem;
      color: var(--text-muted);
      letter-spacing: .1em;
    }
    .codex-rank {
      font-family: 'DM Mono', monospace;
      font-size: .58rem;
      letter-spacing: .12em;
      background: var(--surface2);
      padding: .2rem .6rem;
      border-radius: 99px;
      color: var(--accent);
      border: 1px solid var(--border);
    }

    /* ─────────────────────── MANIFESTO ─────────────────────── */
    #manifesto {
      background: var(--bg);
      text-align: center;
      padding: 10rem 2rem;
    }
    .manifesto-inner { max-width: 860px; margin: 0 auto; }
    .manifesto-quote {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(1.8rem, 4vw, 3.2rem);
      line-height: 1.3;
      color: var(--text);
      margin-bottom: 3rem;
      position: relative;
    }
    .manifesto-quote em { color: var(--accent); font-style: italic; }
    .manifesto-quote strong { color: var(--accent2); font-style: normal; }
    .manifesto-cta {
      display: inline-flex;
      align-items: center;
      gap: .8rem;
      font-family: 'DM Mono', monospace;
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text-muted);
      cursor: pointer;
    }
    .manifesto-cta-arrow {
      width: 36px;
      height: 1px;
      background: var(--accent);
      position: relative;
      transition: width .3s;
    }
    .manifesto-cta-arrow::after {
      content: '';
      position: absolute;
      right: 0; top: -3px;
      border: 4px solid transparent;
      border-left: 6px solid var(--accent);
    }
    .manifesto-cta:hover .manifesto-cta-arrow { width: 56px; }

    /* ─────────────────────── FOOTER ─────────────────────── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--bg);
    }
    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: .18em;
      color: var(--accent);
    }
    .footer-logo span { color: var(--accent2); }
    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: .62rem;
      letter-spacing: .14em;
      color: var(--text-muted);
    }
    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .footer-links a {
      font-family: 'DM Mono', monospace;
      font-size: .65rem;
      letter-spacing: .12em;
      color: var(--text-muted);
      text-decoration: none;
      transition: color .3s;
    }
    .footer-links a:hover { color: var(--accent); }

    /* ─────────────────────── CURSOR ─────────────────────── */
    .cursor {
      position: fixed;
      width: 8px; height: 8px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      mix-blend-mode: difference;
      transform: translate(-50%, -50%);
      transition: transform .1s, width .3s, height .3s, opacity .3s;
    }
    .cursor-ring {
      position: fixed;
      width: 32px; height: 32px;
      border: 1.5px solid var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform .18s ease, width .3s, height .3s, opacity .3s;
      opacity: .5;
    }
    .cursor-ring.hover { width: 56px; height: 56px; opacity: .2; }

    /* ─────────────────────── SCROLL REVEAL ─────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity .8s ease, transform .8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: .1s; }
    .reveal-delay-2 { transition-delay: .2s; }
    .reveal-delay-3 { transition-delay: .35s; }
    .reveal-delay-4 { transition-delay: .5s; }

    /* ─────────────────────── KEYFRAMES ─────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes lineReveal {
      to { transform: scaleX(1); }
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: .3; transform: scaleY(1); }
      50%       { opacity: 1;  transform: scaleY(1.15); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50%       { transform: translateY(-14px); }
    }

    /* ─────────────────────── 3D MARQUEE ─────────────────────── */
    .marquee-wrap {
      position: relative;
      overflow: hidden;
      padding: 1.2rem 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--surface);
    }
    .marquee-track {
      display: flex;
      gap: 3rem;
      animation: marquee 24s linear infinite;
      width: max-content;
    }
    .marquee-wrap:hover .marquee-track { animation-play-state: paused; }
    .marquee-item {
      font-family: 'DM Mono', monospace;
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--text-muted);
      white-space: nowrap;
    }
    .marquee-item .dot {
      color: var(--accent);
      margin-right: 1rem;
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* responsive */
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .frag-grid { grid-template-columns: 1fr; }
      .features-grid { grid-template-columns: 1fr; }
      .feat-card.large { grid-column: span 1; grid-template-columns: 1fr; }
