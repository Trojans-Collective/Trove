<script>
/* ─── Custom Cursor ─── */
const cursor = document.getElementById('cursor');
const cursorRing = document.getElementById('cursor-ring');
let mx = -100, my = -100, rx = -100, ry = -100;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx + 'px';
  cursor.style.top  = my + 'px';
});

// Smooth cursor ring
function animateCursor() {
  rx += (mx - rx) * .1;
  ry += (my - ry) * .1;
  cursorRing.style.left = rx + 'px';
  cursorRing.style.top  = ry + 'px';
  requestAnimationFrame(animateCursor);
}
animateCursor();

document.querySelectorAll('a, button, .rank-card, .codex-card, .feat-card').forEach(el => {
  el.addEventListener('mouseenter', () => cursorRing.classList.add('hover'));
  el.addEventListener('mouseleave', () => cursorRing.classList.remove('hover'));
});

/* ─── Theme Toggle ─── */
const themeToggle = document.getElementById('themeToggle');
const html = document.documentElement;

themeToggle.addEventListener('click', () => {
  const isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  // Reinit canvas colors
  updateCanvasColors();
});

/* ─── 3D Particle Canvas ─── */
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, particles = [], mouseX = 0, mouseY = 0;
const PARTICLE_COUNT = 100;
const GRID_SIZE = 5;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
window.addEventListener('resize', () => { resize(); initParticles(); });
resize();

document.addEventListener('mousemove', e => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

function getColors() {
  const isDark = html.getAttribute('data-theme') === 'dark';
  return {
    particle: isDark ? 'rgba(146,220,229,' : 'rgba(0,120,130,',
    line:     isDark ? 'rgba(146,220,229,' : 'rgba(0,100,110,',
    grid:     isDark ? 'rgba(146,220,229,' : 'rgba(0,100,110,',
  };
}

let colCache = getColors();
function updateCanvasColors() { colCache = getColors(); }

class Particle {
  constructor() { this.reset(true); }
  reset(init = false) {
    this.x  = Math.random() * W;
    this.y  = init ? Math.random() * H : H + 10;
    this.z  = Math.random() * 600 + 100;
    this.vx = (Math.random() - .5) * .3;
    this.vy = -Math.random() * .4 - .1;
    this.vz = (Math.random() - .5) * .5;
    this.r  = Math.random() * 1.5 + .5;
    this.a  = Math.random() * .6 + .1;
    this.life = 0;
    this.maxLife = Math.random() * 400 + 200;
  }
  update() {
    // Mouse parallax
    const dx = mouseX - W / 2;
    const dy = mouseY - H / 2;
    this.x += this.vx + dx * .00008;
    this.y += this.vy + dy * .00008;
    this.z += this.vz;
    this.life++;

    // Project 3D
    const fov = 400;
    const scale = fov / (fov + this.z);
    this.sx = (this.x - W / 2) * scale + W / 2;
    this.sy = (this.y - H / 2) * scale + H / 2;
    this.sr = this.r * scale;
    this.sa = this.a * Math.min(this.life / 60, 1) * (1 - this.life / this.maxLife);

    if (this.y < -20 || this.life > this.maxLife || this.sx < -100 || this.sx > W + 100) this.reset();
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.sx, this.sy, Math.max(.1, this.sr), 0, Math.PI * 2);
    ctx.fillStyle = colCache.particle + this.sa + ')';
    ctx.fill();
  }
}

function initParticles() {
  particles = [];
  for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());
}
initParticles();

// Perspective grid
function drawGrid() {
  const cols = getColors();
  const horizon = H * .52;
  const fov = 600;
  const vp = W / 2;
  const gLines = 14;
  const gRows  = 10;

  ctx.save();
  // vertical lines
  for (let i = -gLines; i <= gLines; i++) {
    const worldX = i * 80;
    const x1 = vp + worldX;
    const y1 = horizon;
    const factor = H / (H - horizon);
    const x2 = vp + worldX * factor * 3;
    const y2 = H;
    const alpha = Math.max(0, .12 - Math.abs(i) * .008);
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = cols.grid + alpha + ')';
    ctx.lineWidth = .6;
    ctx.stroke();
  }
  // horizontal lines
  for (let j = 0; j <= gRows; j++) {
    const t = j / gRows;
    const y = horizon + (H - horizon) * Math.pow(t, 1.5);
    const spread = 200 + (y - horizon) / (H - horizon) * W * 1.5;
    ctx.beginPath();
    ctx.moveTo(vp - spread, y);
    ctx.lineTo(vp + spread, y);
    const a = t * .12;
    ctx.strokeStyle = cols.grid + a + ')';
    ctx.lineWidth = .6;
    ctx.stroke();
  }
  ctx.restore();
}

// Connect nearby particles
function drawConnections() {
  const cols = getColors();
  for (let i = 0; i < particles.length; i++) {
    for (let j = i + 1; j < particles.length; j++) {
      const p1 = particles[i], p2 = particles[j];
      const dx = p1.sx - p2.sx, dy = p1.sy - p2.sy;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 90) {
        const a = (1 - dist / 90) * .12;
        ctx.beginPath();
        ctx.moveTo(p1.sx, p1.sy);
        ctx.lineTo(p2.sx, p2.sy);
        ctx.strokeStyle = cols.line + a + ')';
        ctx.lineWidth = .5;
        ctx.stroke();
      }
    }
  }
}

// Scroll-driven depth
let scrollY = 0;
window.addEventListener('scroll', () => { scrollY = window.scrollY; });

function animate() {
  ctx.clearRect(0, 0, W, H);

  // Scroll tilt effect on grid
  ctx.save();
  const tilt = scrollY * .01;
  ctx.transform(1, 0, 0, 1, 0, scrollY * .08);

  drawGrid();
  drawConnections();

  particles.forEach(p => {
    p.vx += (mouseX - p.sx) * .000004;
    p.update();
    p.draw();
  });
  ctx.restore();
  requestAnimationFrame(animate);
}
animate();

/* ─── Scroll Reveal ─── */
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); }
  });
}, { threshold: .12 });
reveals.forEach(el => observer.observe(el));

/* ─── Counter animation ─── */
function animateCounter(el, end, suffix = '') {
  let start = 0;
  const duration = 1600;
  const step = (timestamp) => {
    if (!start) start = timestamp;
    const progress = Math.min((timestamp - start) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    el.textContent = Math.floor(eased * end) + suffix;
    if (progress < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

const statNums = document.querySelectorAll('.stat-num[data-count]');
const statObserver = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const end = parseInt(e.target.dataset.count);
      const suffix = e.target.dataset.suffix || '';
      if (end === 0) { e.target.textContent = '∞'; return; }
      animateCounter(e.target, end, suffix);
      statObserver.unobserve(e.target);
    }
  });
}, { threshold: .5 });
statNums.forEach(el => statObserver.observe(el));

/* ─── Activity Matrix ─── */
const matrix = document.getElementById('matrixPreview');
if (matrix) {
  const levels = ['', 'active-1', 'active-2', 'active-3', 'active-4'];
  const weights = [3, 3, 2, 1.5, .5];
  for (let i = 0; i < 100; i++) {
    const dot = document.createElement('div');
    dot.className = 'matrix-dot';
    // Weighted random
    const rand = Math.random();
    let cumulative = 0, chosen = 0;
    const total = weights.reduce((a, b) => a + b, 0);
    for (let w = 0; w < weights.length; w++) {
      cumulative += weights[w] / total;
      if (rand < cumulative) { chosen = w; break; }
    }
    if (chosen > 0) dot.classList.add(levels[chosen]);
    matrix.appendChild(dot);
  }
}

/* ─── 3D tilt on rank cards ─── */
document.querySelectorAll('.rank-card, .codex-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width  - .5;
    const y = (e.clientY - rect.top)  / rect.height - .5;
    card.style.transform = `perspective(600px) rotateY(${x * 16}deg) rotateX(${-y * 10}deg) translateY(-6px)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = '';
  });
});

/* ─── Floating 3D parallax on hero elements ─── */
document.addEventListener('mousemove', e => {
  const x = (e.clientX / W - .5);
  const y = (e.clientY / H - .5);
  const title = document.querySelector('.hero-title');
  const sub   = document.querySelector('.hero-sub');
  if (title) title.style.transform = `perspective(900px) rotateY(${x * 5}deg) rotateX(${-y * 3}deg)`;
  if (sub)   sub.style.transform   = `perspective(900px) rotateY(${x * 2}deg) rotateX(${-y * 1}deg)`;
});
</script>
