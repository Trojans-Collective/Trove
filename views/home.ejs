<!-- ════════════════ SCRIPT ════════════════ -->
<script>
/* ── Cursor ── */
const cursor = document.getElementById('cursor');
const cursorRing = document.getElementById('cursorRing');
let mx=-100,my=-100,rx=-100,ry=-100;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cursor.style.left=mx+'px';cursor.style.top=my+'px';
});
(function animCursor(){
  rx+=(mx-rx)*.12;ry+=(my-ry)*.12;
  cursorRing.style.left=rx+'px';cursorRing.style.top=ry+'px';
  requestAnimationFrame(animCursor);
})();
document.querySelectorAll('button,a,.nav-item,.leader-item,.codex-item,.arena-project-card,.ai-card,.beacon-card,.rank-card,.codex-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>cursorRing.classList.add('big'));
  el.addEventListener('mouseleave',()=>cursorRing.classList.remove('big'));
});

/* ── Theme Toggle ── */
document.getElementById('themeToggle').addEventListener('click',()=>{
  const d=document.documentElement;
  d.setAttribute('data-theme',d.getAttribute('data-theme')==='dark'?'light':'dark');
});

/* ── Navigation ── */
function navigate(page){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const target = document.getElementById('page-'+page);
  if(target) target.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>{
    if(n.getAttribute('onclick')&&n.getAttribute('onclick').includes("'"+page+"'")){
      n.classList.add('active');
    }
  });
  // Scroll main to top
  document.querySelector('.main').scrollTop=0;
}

/* ── Feed Tabs ── */
function setTab(el){
  document.querySelectorAll('.feed-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}

/* ── Like post ── */
function likePost(btn){
  btn.classList.toggle('liked');
  const span=btn.querySelector('.action-icon');
  const text=btn.childNodes[btn.childNodes.length-1];
  const current=parseInt(btn.textContent.replace(/[^0-9]/g,''));
  const newCount=btn.classList.contains('liked')?current+1:current-1;
  btn.innerHTML=`<span class="action-icon">⚡</span> ${newCount}`;
}

/* ── Toast ── */
function showToast(){
  const t=document.getElementById('toast');
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

/* ── Mini Matrix ── */
const levels=['','l1','l2','l3','l4'];
const weights=[2,2,2,1.5,.5];
function randomLevel(){
  const total=weights.reduce((a,b)=>a+b,0);
  let r=Math.random()*total,c=0;
  for(let i=0;i<weights.length;i++){c+=weights[i];if(r<c)return i;}
  return 0;
}
const mm=document.getElementById('miniMatrix');
if(mm){for(let i=0;i<56;i++){const d=document.createElement('div');d.className='mm-dot';const l=randomLevel();if(l>0)d.classList.add(levels[l]);mm.appendChild(d);}}

const pm=document.getElementById('profileMatrix');
if(pm){for(let i=0;i<182;i++){const d=document.createElement('div');d.className='pm-dot';const l=randomLevel();if(l>0)d.classList.add('l'+l);pm.appendChild(d);}}

/* ── XP bar animation ── */
setTimeout(()=>{
  const fill=document.getElementById('xpFill');
  if(fill)fill.style.width='62%';
},500);

/* ── Post card entrance stagger ── */
document.querySelectorAll('.post-card').forEach((c,i)=>{
  c.style.animationDelay=(i*.1)+'s';
});

/* ── Hover 3D tilt on arena cards ── */
document.querySelectorAll('.arena-project-card,.ai-card,.beacon-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=(e.clientX-r.left)/r.width-.5;
    const y=(e.clientY-r.top)/r.height-.5;
    card.style.transform=`perspective(600px) rotateY(${x*10}deg) rotateX(${-y*6}deg) translateY(-4px)`;
  });
  card.addEventListener('mouseleave',()=>{card.style.transform='';});
});

/* ── Scroll reveal for right-panel blocks ── */
const rpBlocks=document.querySelectorAll('.rp-block');
rpBlocks.forEach((b,i)=>{
  b.style.opacity='0';
  b.style.transform='translateX(20px)';
  b.style.transition=`opacity .5s ${i*.08}s ease, transform .5s ${i*.08}s ease`;
  setTimeout(()=>{b.style.opacity='1';b.style.transform='translateX(0)';},100+i*80);
});

/* ── Sidebar nav entrance ── */
document.querySelectorAll('.nav-item').forEach((item,i)=>{
  item.style.opacity='0';
  item.style.transform='translateX(-16px)';
  item.style.transition=`opacity .4s ${i*.04}s ease, transform .4s ${i*.04}s ease`;
  setTimeout(()=>{item.style.opacity='1';item.style.transform='translateX(0)';},80+i*40);
});

/* ── Show rank-up toast after 2s ── */
setTimeout(showToast,2200);
</script>

