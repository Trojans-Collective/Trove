<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TROVE — Builder Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>

<style>
/* ═══════════════════════════════════════════
   TOKENS
═══════════════════════════════════════════ */
:root {
  --c-black:  #000000;
  --c-cyan:   #92DCE5;
  --c-cream:  #EEE5E9;
  --c-grey:   #7C7C7C;
  --c-red:    #D64933;
  --trans: .5s cubic-bezier(.77,0,.18,1);
  --sidebar-w: 260px;
  --topbar-h:  58px;
  --right-w:   300px;
  --radius: 6px;
}

[data-theme="dark"] {
  --bg:       #050505;
  --bg2:      #0c0c0c;
  --surface:  #111111;
  --surface2: #181818;
  --surface3: #202020;
  --border:   rgba(146,220,229,.1);
  --border2:  rgba(146,220,229,.06);
  --text:     #EEE5E9;
  --text2:    #a0a0a0;
  --text3:    #5c5c5c;
  --accent:   #92DCE5;
  --accent2:  #D64933;
  --glow:     rgba(146,220,229,.15);
  --glow2:    rgba(214,73,51,.12);
  --gold:     #c9a84c;
  --army-line:rgba(146,220,229,.04);
}
[data-theme="light"] {
  --bg:       #EEE5E9;
  --bg2:      #e4dade;
  --surface:  #f5f0f2;
  --surface2: #ffffff;
  --surface3: #fdfafb;
  --border:   rgba(0,0,0,.1);
  --border2:  rgba(0,0,0,.05);
  --text:     #0a0a0a;
  --text2:    #5a5a5a;
  --text3:    #9a9a9a;
  --accent:   #1a7a85;
  --accent2:  #D64933;
  --glow:     rgba(26,122,133,.1);
  --glow2:    rgba(214,73,51,.08);
  --gold:     #a07820;
  --army-line:rgba(0,0,0,.03);
}

/* ═══════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{
  font-family:'Syne',sans-serif;
  background:var(--bg);
  color:var(--text);
  display:grid;
  grid-template-rows:var(--topbar-h) 1fr;
  grid-template-columns:var(--sidebar-w) 1fr var(--right-w);
  transition:background var(--trans),color var(--trans);
}

/* army cross-hatch pattern overlay */
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:
    repeating-linear-gradient(0deg, var(--army-line) 0, var(--army-line) 1px, transparent 1px, transparent 40px),
    repeating-linear-gradient(90deg, var(--army-line) 0, var(--army-line) 1px, transparent 1px, transparent 40px);
  pointer-events:none;
  z-index:0;
}

/* ═══════════════════════════════════════════
   TOPBAR
═══════════════════════════════════════════ */
.topbar{
  grid-column:1/-1;
  grid-row:1;
  display:flex;
  align-items:center;
  padding:0 1.2rem;
  gap:1rem;
  border-bottom:1px solid var(--border);
  background:var(--bg);
  z-index:100;
  position:relative;
}
.topbar::after{
  content:'';
  position:absolute;
  bottom:-1px;left:0;right:0;
  height:1px;
  background:linear-gradient(to right, var(--accent), transparent 60%);
  opacity:.4;
}

.topbar-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.6rem;
  letter-spacing:.15em;
  color:var(--accent);
  text-decoration:none;
  flex-shrink:0;
  width:calc(var(--sidebar-w) - 1.2rem);
}
.topbar-logo span{color:var(--accent2);}

.topbar-search{
  flex:1;
  display:flex;
  align-items:center;
  gap:.6rem;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:.5rem 1rem;
  max-width:440px;
}
.topbar-search input{
  background:none;
  border:none;
  outline:none;
  font-family:'DM Mono',monospace;
  font-size:.75rem;
  color:var(--text);
  width:100%;
  letter-spacing:.05em;
}
.topbar-search input::placeholder{color:var(--text3);}
.search-icon{color:var(--text3);font-size:.85rem;flex-shrink:0;}

.topbar-right{
  margin-left:auto;
  display:flex;
  align-items:center;
  gap:.8rem;
}

.topbar-xp{
  display:flex;
  align-items:center;
  gap:.5rem;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:99px;
  padding:.3rem .8rem .3rem .5rem;
}
.xp-icon{font-size:.85rem;}
.xp-label{
  font-family:'DM Mono',monospace;
  font-size:.62rem;
  letter-spacing:.12em;
  color:var(--accent);
}

.topbar-notif{
  width:34px;height:34px;
  border-radius:50%;
  background:var(--surface);
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  font-size:.9rem;
  position:relative;
  transition:border-color .25s;
}
.topbar-notif:hover{border-color:var(--accent);}
.notif-dot{
  position:absolute;top:5px;right:5px;
  width:7px;height:7px;
  border-radius:50%;
  background:var(--accent2);
  border:1.5px solid var(--bg);
  animation:pulse 2s infinite;
}

.theme-toggle{
  width:50px;height:26px;
  border-radius:99px;
  background:var(--surface2);
  border:1.5px solid var(--border);
  cursor:pointer;
  position:relative;
  overflow:hidden;
  transition:background .4s,border .4s;
  flex-shrink:0;
}
.theme-toggle::before{
  content:'';
  position:absolute;
  top:2px;left:2px;
  width:19px;height:19px;
  border-radius:50%;
  background:var(--accent);
  transition:transform .45s cubic-bezier(.34,1.56,.64,1),background .4s;
}
[data-theme="light"] .theme-toggle::before{transform:translateX(23px);background:var(--accent2);}

.topbar-avatar{
  width:34px;height:34px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:.75rem;font-weight:700;
  color:#000;
  cursor:pointer;
  transition:border-color .25s,transform .25s;
  flex-shrink:0;
}
.topbar-avatar:hover{border-color:var(--accent);transform:scale(1.08);}

/* ═══════════════════════════════════════════
   SIDEBAR
═══════════════════════════════════════════ */
.sidebar{
  grid-row:2;
  grid-column:1;
  border-right:1px solid var(--border);
  background:var(--bg);
  display:flex;
  flex-direction:column;
  overflow-y:auto;
  scrollbar-width:none;
  z-index:10;
  position:relative;
}
.sidebar::-webkit-scrollbar{display:none;}

/* rank banner */
.sidebar-rank{
  padding:1.2rem 1.1rem .8rem;
  border-bottom:1px solid var(--border2);
  display:flex;
  align-items:center;
  gap:.8rem;
  cursor:pointer;
  transition:background .25s;
}
.sidebar-rank:hover{background:var(--surface);}
.rank-emblem{
  width:44px;height:44px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--surface2),var(--surface3));
  border:1.5px solid var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-size:1.3rem;
  box-shadow:0 0 12px rgba(201,168,76,.2);
  flex-shrink:0;
  animation:emblemGlow 3s ease-in-out infinite;
}
@keyframes emblemGlow{
  0%,100%{box-shadow:0 0 12px rgba(201,168,76,.2);}
  50%    {box-shadow:0 0 22px rgba(201,168,76,.45);}
}
.rank-info{flex:1;min-width:0;}
.rank-name{
  font-family:'Bebas Neue',sans-serif;
  font-size:1rem;
  letter-spacing:.12em;
  color:var(--gold);
  line-height:1;
}
.rank-sub{
  font-family:'DM Mono',monospace;
  font-size:.58rem;
  color:var(--text3);
  letter-spacing:.12em;
  margin-top:.15rem;
}
.rank-xp-bar{
  height:3px;
  background:var(--surface3);
  border-radius:99px;
  margin-top:.5rem;
  overflow:hidden;
}
.rank-xp-fill{
  height:100%;
  width:38%;
  background:linear-gradient(to right,var(--gold),var(--accent));
  border-radius:99px;
  transition:width 1s ease;
}

/* nav sections */
.nav-section-label{
  font-family:'DM Mono',monospace;
  font-size:.55rem;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--text3);
  padding:.9rem 1.1rem .4rem;
}

.nav-item{
  display:flex;
  align-items:center;
  gap:.75rem;
  padding:.7rem 1.1rem;
  cursor:pointer;
  border-radius:0;
  position:relative;
  transition:background .2s,color .2s;
  border-left:2px solid transparent;
  text-decoration:none;
  color:var(--text2);
}
.nav-item:hover{background:var(--surface);color:var(--text);}
.nav-item.active{
  background:var(--surface);
  color:var(--accent);
  border-left-color:var(--accent);
}
.nav-item.active .nav-icon{color:var(--accent);}
.nav-icon{
  width:28px;height:28px;
  border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  background:var(--surface2);
  border:1px solid var(--border2);
  flex-shrink:0;
  transition:background .2s,border-color .2s;
}
.nav-item.active .nav-icon,.nav-item:hover .nav-icon{
  background:var(--surface3);
  border-color:var(--border);
}
.nav-label{
  font-family:'Syne',sans-serif;
  font-size:.8rem;
  font-weight:600;
  flex:1;
}
.nav-badge{
  font-family:'DM Mono',monospace;
  font-size:.55rem;
  letter-spacing:.1em;
  background:var(--accent2);
  color:#fff;
  padding:.15rem .45rem;
  border-radius:99px;
}
.nav-badge.green{background:var(--accent);color:#000;}

/* mini matrix in sidebar */
.sidebar-matrix{
  margin:.8rem 1.1rem;
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  padding:.8rem;
}
.matrix-label{
  font-family:'DM Mono',monospace;
  font-size:.58rem;
  letter-spacing:.15em;
  color:var(--text3);
  margin-bottom:.6rem;
}
.mini-matrix{
  display:grid;
  grid-template-columns:repeat(14,1fr);
  gap:2px;
}
.mm-dot{
  aspect-ratio:1;
  border-radius:2px;
  background:var(--surface2);
}
.mm-dot.l1{background:rgba(146,220,229,.15);}
.mm-dot.l2{background:rgba(146,220,229,.35);}
.mm-dot.l3{background:rgba(146,220,229,.6);}
.mm-dot.l4{background:#92DCE5;}
.matrix-streak{
  font-family:'DM Mono',monospace;
  font-size:.6rem;
  color:var(--accent);
  margin-top:.5rem;
  letter-spacing:.1em;
}

.sidebar-footer{
  margin-top:auto;
  padding:1rem 1.1rem;
  border-top:1px solid var(--border2);
  display:flex;
  gap:.6rem;
}
.sidebar-footer-btn{
  flex:1;
  padding:.5rem;
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  cursor:pointer;
  font-family:'DM Mono',monospace;
  font-size:.6rem;
  letter-spacing:.1em;
  color:var(--text2);
  text-align:center;
  transition:border-color .25s,color .25s;
}
.sidebar-footer-btn:hover{border-color:var(--accent);color:var(--accent);}

/* ═══════════════════════════════════════════
   MAIN CONTENT
═══════════════════════════════════════════ */
.main{
  grid-row:2;
  grid-column:2;
  overflow-y:auto;
  scrollbar-width:thin;
  scrollbar-color:var(--border) transparent;
  position:relative;
  z-index:1;
}
.main::-webkit-scrollbar{width:4px;}
.main::-webkit-scrollbar-track{background:transparent;}
.main::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}

.page{display:none;}
.page.active{display:block;animation:pageIn .4s ease;}
@keyframes pageIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* ── Feed Page ── */
#page-feed{padding:1.5rem;}

.feed-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:1.2rem;
}
.feed-header h2{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.4rem;
  letter-spacing:.1em;
  color:var(--text);
}
.feed-tabs{
  display:flex;
  gap:.3rem;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:3px;
}
.feed-tab{
  font-family:'DM Mono',monospace;
  font-size:.62rem;
  letter-spacing:.1em;
  padding:.35rem .8rem;
  border-radius:4px;
  cursor:pointer;
  color:var(--text2);
  transition:background .2s,color .2s;
  border:none;
  background:none;
}
.feed-tab.active{background:var(--accent);color:#000;font-weight:500;}

/* Compose box */
.compose-box{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:1rem 1.2rem;
  margin-bottom:1.2rem;
  transition:border-color .25s,box-shadow .25s;
}
.compose-box:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow);}
.compose-top{display:flex;gap:.9rem;align-items:flex-start;}
.compose-avatar{
  width:36px;height:36px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  display:flex;align-items:center;justify-content:center;
  font-size:.7rem;font-weight:700;color:#000;
  flex-shrink:0;
  border:1.5px solid var(--border);
}
.compose-input{
  flex:1;
  background:none;
  border:none;
  outline:none;
  font-family:'Syne',sans-serif;
  font-size:.85rem;
  color:var(--text);
  resize:none;
  min-height:60px;
  line-height:1.5;
  padding-top:.2rem;
}
.compose-input::placeholder{color:var(--text3);}
.compose-actions{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-top:.8rem;
  padding-top:.8rem;
  border-top:1px solid var(--border2);
}
.compose-tools{display:flex;gap:.5rem;}
.compose-tool-btn{
  width:30px;height:30px;
  border-radius:var(--radius);
  border:1px solid var(--border2);
  background:var(--surface2);
  cursor:pointer;
  font-size:.85rem;
  display:flex;align-items:center;justify-content:center;
  transition:border-color .2s,transform .2s;
  color:var(--text2);
}
.compose-tool-btn:hover{border-color:var(--accent);transform:scale(1.1);}
.compose-post-btn{
  font-family:'DM Mono',monospace;
  font-size:.68rem;
  letter-spacing:.1em;
  padding:.4rem 1.1rem;
  background:var(--accent);
  color:#000;
  border:none;
  border-radius:var(--radius);
  cursor:pointer;
  font-weight:500;
  transition:transform .2s,box-shadow .2s;
}
.compose-post-btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px var(--glow);}

/* Post card */
.post-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  margin-bottom:1rem;
  overflow:hidden;
  transition:border-color .25s,box-shadow .25s;
  animation:cardIn .5s ease both;
}
.post-card:hover{border-color:var(--border);box-shadow:0 4px 24px var(--glow2);}
@keyframes cardIn{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}
.post-card:nth-child(1){animation-delay:.05s;}
.post-card:nth-child(2){animation-delay:.12s;}
.post-card:nth-child(3){animation-delay:.19s;}
.post-card:nth-child(4){animation-delay:.26s;}

.post-header{
  display:flex;
  align-items:flex-start;
  gap:.9rem;
  padding:1rem 1.2rem .7rem;
}
.post-avatar{
  width:40px;height:40px;
  border-radius:50%;
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:.8rem;font-weight:700;color:#000;
  border:1.5px solid var(--border);
}
.post-meta{flex:1;}
.post-name{
  font-family:'Syne',sans-serif;
  font-size:.85rem;
  font-weight:700;
  display:flex;align-items:center;gap:.5rem;
}
.post-rank-badge{
  font-family:'DM Mono',monospace;
  font-size:.52rem;
  letter-spacing:.12em;
  padding:.1rem .45rem;
  border-radius:99px;
  border:1px solid var(--gold);
  color:var(--gold);
}
.post-detail{
  font-family:'DM Mono',monospace;
  font-size:.6rem;
  color:var(--text3);
  letter-spacing:.08em;
  margin-top:.18rem;
}
.post-more{
  margin-left:auto;
  cursor:pointer;
  color:var(--text3);
  font-size:1rem;
  padding:.2rem .5rem;
  border-radius:4px;
  transition:color .2s,background .2s;
}
.post-more:hover{color:var(--text);background:var(--surface2);}

.post-body{
  padding:.2rem 1.2rem .8rem;
  font-size:.85rem;
  line-height:1.7;
  color:var(--text);
}
.post-body .tag{
  color:var(--accent);
  font-weight:600;
}
.post-tag-chip{
  display:inline-flex;
  align-items:center;
  gap:.3rem;
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:99px;
  padding:.2rem .7rem;
  font-family:'DM Mono',monospace;
  font-size:.6rem;
  letter-spacing:.1em;
  color:var(--text2);
  margin:.4rem .3rem 0 0;
}

/* code snippet in post */
.post-code-block{
  margin:.7rem 0;
  background:var(--bg2);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  padding:.8rem 1rem;
  font-family:'DM Mono',monospace;
  font-size:.72rem;
  color:var(--accent);
  line-height:1.7;
  overflow-x:auto;
  position:relative;
}
.post-code-block::before{
  content:attr(data-lang);
  position:absolute;top:.4rem;right:.7rem;
  font-size:.55rem;
  letter-spacing:.15em;
  color:var(--text3);
  text-transform:uppercase;
}

/* project card inside post */
.post-project-card{
  margin:.7rem 0;
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  transition:border-color .25s;
  cursor:pointer;
}
.post-project-card:hover{border-color:var(--accent);}
.ppc-banner{
  height:80px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Bebas Neue',sans-serif;
  font-size:1.8rem;
  letter-spacing:.15em;
  color:var(--accent);
  background:linear-gradient(135deg,var(--surface) 0%,var(--surface2) 100%);
  border-bottom:1px solid var(--border2);
  position:relative;
  overflow:hidden;
}
.ppc-banner::after{
  content:'';
  position:absolute;inset:0;
  background:repeating-linear-gradient(
    45deg,transparent,transparent 10px,var(--army-line) 10px,var(--army-line) 11px
  );
}
.ppc-info{padding:.7rem 1rem;display:flex;align-items:center;justify-content:space-between;}
.ppc-name{font-size:.8rem;font-weight:700;}
.ppc-tech{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--text3);letter-spacing:.08em;}
.ppc-stars{color:var(--gold);font-size:.75rem;}

/* achievement post */
.post-achievement{
  margin:.7rem 0;
  background:linear-gradient(135deg,var(--surface2),var(--surface));
  border:1px solid var(--gold);
  border-radius:var(--radius);
  padding:.9rem 1.1rem;
  display:flex;
  align-items:center;
  gap:1rem;
  box-shadow:0 0 20px rgba(201,168,76,.08);
}
.achievement-icon{font-size:2rem;}
.achievement-text{flex:1;}
.achievement-title{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.1em;color:var(--gold);}
.achievement-desc{font-size:.72rem;color:var(--text2);margin-top:.2rem;}

.post-footer{
  padding:.6rem 1.2rem;
  border-top:1px solid var(--border2);
  display:flex;
  align-items:center;
  gap:1rem;
}
.post-action{
  display:flex;align-items:center;gap:.4rem;
  font-family:'DM Mono',monospace;
  font-size:.65rem;
  letter-spacing:.08em;
  color:var(--text2);
  cursor:pointer;
  padding:.35rem .6rem;
  border-radius:var(--radius);
  transition:background .2s,color .2s;
  border:none;background:none;
}
.post-action:hover{background:var(--surface2);color:var(--accent);}
.post-action.liked{color:var(--accent2);}
